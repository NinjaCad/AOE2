(defrule
	(timer-triggered retask-timer)
(or	(and	(wood-amount < 200)
		(food-amount > 1500))
	(and	(wood-amount < 500)
		(food-amount > 3000)))
	(goal retask yes)
=>
	(set-strategic-number sn-wood-modifier-percentage 5)
	(set-strategic-number sn-food-modifier-percentage -5)
	(chat-local-to-self "Retasking for 5% more wood and less food gatherers.")
	(set-goal retask no))

(defrule
	(timer-triggered retask-timer)
(or	(and	(food-amount < 200)
		(wood-amount > 1500))
	(and	(food-amount < 500)
		(wood-amount > 3000)))
	(goal retask yes)
=>
	(set-strategic-number sn-food-modifier-percentage 5)
	(set-strategic-number sn-wood-modifier-percentage -5)
	(chat-local-to-self "Retasking for 5% more food and less wood gatherers.")
	(set-goal retask no))

(defrule
	(timer-triggered retask-timer)
=>
	(set-strategic-number sn-food-gatherer-percentage  ig-food); normalize g-percentages
	(set-strategic-number sn-gold-gatherer-percentage  ig-gold)
	(set-strategic-number sn-stone-gatherer-percentage ig-stone)
	(set-strategic-number sn-wood-gatherer-percentage  ig-wood))

(defrule
	(timer-triggered retask-timer)
(or	(up-compare-goal threat-time >= 120000)
(or	(goal attacking yes)
	(goal defend no))); no killed vills
=>
	(up-modify-sn sn-food-gatherer-percentage s:+ sn-food-modifier-percentage)
	(up-modify-sn sn-gold-gatherer-percentage s:+ sn-gold-modifier-percentage)
	(up-modify-sn sn-wood-gatherer-percentage s:+ sn-wood-modifier-percentage)
	(up-modify-sn sn-stone-gatherer-percentage s:+ sn-stone-modifier-percentage)
	(set-strategic-number sn-food-modifier-percentage 0)
	(set-strategic-number sn-gold-modifier-percentage 0)
	(set-strategic-number sn-wood-modifier-percentage 0)
	(set-strategic-number sn-stone-modifier-percentage 0))

(defrule
	(timer-triggered retask-timer)
	(up-compare-goal threat-time < 120000)
	(goal attacking no)
	(goal defend yes); either the enemy or the AI himself killed some villagers
=>
	(set-strategic-number sn-food-modifier-percentage 0)
	(set-strategic-number sn-gold-modifier-percentage 0)
	(set-strategic-number sn-wood-modifier-percentage 0)
	(set-strategic-number sn-stone-modifier-percentage 0))

(defrule
	(timer-triggered retask-timer)
	(goal retask no)
=>
	(disable-timer retask-timer)
	(set-goal retask yes)
	(enable-timer retask-timer 180))





