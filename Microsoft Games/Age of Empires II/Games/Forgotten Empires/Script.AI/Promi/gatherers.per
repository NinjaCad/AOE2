	(building-type-count-total town-center >= 1)
	(game-time > 5)
	(game-time < 11)
	(strategic-number sn-camp-max-distance == 16)
	(resource-found wood)
=>
	(set-strategic-number sn-camp-max-distance 14)
	(chat-local-to-self "Camp-max-distance 14.")
	(disable-self))

(defrule
	(building-type-count-total town-center >= 1)
	(game-time > 10)
	(game-time < 14)
	(strategic-number sn-camp-max-distance == 16)
	(resource-found wood)
=>
	(set-strategic-number sn-camp-max-distance 16)
	(chat-local-to-self "Camp-max-distance 16.")
	(disable-self))

(defrule
	(timer-triggered lc2)
	(cc-players-unit-type-count gaia shore-fish > 0)
	(map-type arabia)
=>
	(disable-timer lc2)
	(set-strategic-number sn-camp-max-distance 19)
	(chat-local-to-self "Camp-max-distance 19.")
	(disable-self))

(defrule
	(timer-triggered lc2)
	(cc-players-unit-type-count gaia shore-fish < 1)
	(map-type arabia)
=>
	(disable-timer lc2)
	(set-strategic-number sn-camp-max-distance 18)
	(chat-local-to-self "Camp-max-distance 18.")
	(disable-self))

(defrule
	(timer-triggered lc2)
(not	(map-type arabia))
(not	(map-type gold-rush))
=>
	(disable-timer lc2)
	(set-strategic-number sn-camp-max-distance 22)
	(chat-local-to-self "Camp-max-distance 22.")
	(disable-self))

(defrule
	(timer-triggered lc2)
	(map-type gold-rush)
=>
	(disable-timer lc2)
	(set-strategic-number sn-camp-max-distance 14)
	(chat-local-to-self "Camp-max-distance 14.")
	(disable-self))

