(defrule
	(goal enemy-goal drush)
=>
	(chat-to-player my-player-number "Possible enemy drush detected.")
	(disable-self))

(defrule
	(goal enemy-goal flush)
=>
	(chat-to-player my-player-number "Possible enemy flush detected.")
	(disable-self))

(defrule
	(game-time <= 1050);17:30
	(players-current-age focus-player >= castle-age)
(not	(goal enemy-goal rush))
=>
	(enable-timer scout 30)
	(set-goal enemy-goal rush)
	(chat-to-player my-player-number "Enemy might try to rush us."))

(defrule
	(game-time <= 1100);18:20
	(players-military-population focus-player <= 3)
	(players-current-age focus-player >= castle-age)
(not	(goal enemy-goal rush))
=>
	(enable-timer scout 30)
	(set-goal enemy-goal rush)
	(chat-to-player my-player-number "Enemy might try to rush us."))

(defrule
(or	(game-time >= 900)
	(and	(current-age >= feudal-age)
		(building-type-count-total archery-range >= 1)))
	(goal enemy-goal drush)
	(goal underattack no)
	(strategic-number my-sn-military-superiority >= -1)
=>
	(set-goal enemy-goal 0))

(defrule
	(game-time >= 1080)
	(goal enemy-goal flush)
	(goal underattack no)
	(strategic-number my-sn-military-superiority >= 0)
=>
	(set-goal enemy-goal 0))

(defrule
	(game-time >= 1350)
	(goal enemy-goal rush)
	(goal underattack no)
	(strategic-number my-sn-military-superiority >= 0)
=>
	(set-goal enemy-goal 0))

(defrule; saving gold for e-skirms when possible
	(current-age >= castle-age)
	(building-type-count-total archery-range >= 1)
	(unit-type-count-total skirmisher-line >= 6); only save up when needed
	(goal e-skirm no)
	(goal e-skirmgold yes)
	(gold-amount < 160)
=>
	(set-goal e-skirmgold no))

(defrule
	(current-age >= castle-age)
(or	(building-type-count-total archery-range <= 0)
	(unit-type-count-total skirmisher-line < 6)); only save up when needed
	(goal e-skirmgold no)
(or	(goal e-skirm yes)
	(gold-amount >= 160))
=>
	(set-goal e-skirmgold yes))

(defrule
	(timer-triggered rebuild-camp)
=>
	(set-goal rebuildcamp yes)
	(disable-timer rebuild-camp))