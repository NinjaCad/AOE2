(defrule
	(true)
=>
	(up-modify-goal temporary-goal2 s:= sn-focus-player-number)
	(set-strategic-number sn-focus-player-number 0))
(defrule ; Those two rules are based on archons code.
	(game-time > 1)
	(up-timer-status sheepscout != timer-running)
	(game-time < 240)
	(up-gaia-type-count c: 958 > 0)
=>
	(set-strategic-number sn-focus-player-number 0)
	(up-get-point position-self point-x)
	(up-set-target-point point-x)
	(up-reset-search 1 1 1 1)
	(up-filter-include -1 -1 -1 -1)
	(up-filter-exclude -1 -1 -1 -1)
	(up-filter-range -1 -1 -1 24))
(defrule
	(up-timer-status sheepscout != timer-running)
	(game-time > 1)
	(game-time < 240)
	(up-find-remote c: 958 c: 1)
=>
;	(chat-to-player my-player-number "Come here kitty kitty.")
	(up-set-target-object search-remote c: 0)
	(up-find-local c: scout-unit c: 1)
	(up-get-point position-object point-x)
	(up-target-point point-x action-move -1 -1)
	(enable-timer sheepscout 10))
(defrule
	(true)
=>
	(up-modify-sn sn-focus-player-number g:= temporary-goal2))

#load-if-not-defined DEATH-MATCH ; Heavily inspired by II2N
(defrule
(or	(goal deer-luring 3)
(or	(game-time >= 780); else probably deer hunting anyway
(or	(game-time < 240)
(or	(and	(up-compare-goal strategy != usual)
		(game-time s:>= sn-home-exploration-time))
	(and	(building-type-count-total dock == 0)
		(goal map water))))))
=>
	(up-jump-rule 11))

(defrule
(or	(and	(up-gaia-type-count-total c: 48 < 2); wild boar
		(and	(up-gaia-type-count-total c: 810 < 2); iron boar
			(and	(up-gaia-type-count-total c: 822 < 2); javelina
				(game-time < 330))))
(or	(unit-type-count scout-unit == 0)
	(building-type-count town-center == 0)))
=>
	(up-jump-rule 10))

(defrule
	(true)
=>
	(up-modify-goal temporary-goal2 s:= sn-focus-player-number)
	(set-strategic-number sn-focus-player-number 0))

(defrule
(or	(dropsite-min-distance deer-hunting < 32)
	(goal deer-luring 1))
=>
	(up-get-point position-self point-x)
	(up-set-target-point point-x)
	(up-reset-search 1 1 1 1)
	(up-reset-filters)
	(up-filter-distance c: -1 c: 31)
	(up-find-remote c: deer c: 1)
	(up-get-search-state local-total))

(defrule
(or	(dropsite-min-distance deer-hunting < 32)
	(goal deer-luring 1))
(or	(goal remote-last 0)
(or	(and	(dropsite-min-distance deer-hunting > 15)
		(or	(building-type-count wall-class > 0); fortress/arena etc.
			(building-type-count gate > 0)))
	(strategic-number sn-preferred-mill-placement == 1))); milling deer anyway
	(up-compare-goal deer-luring != 3)
=>
	(set-goal deer-luring 3)
	(chat-local-to-self "Deer luring disabled => Scouting.")
	(up-send-scout group-type-land-explore scouting-type))

(defrule
(not	(up-set-target-by-id g: stored-id))
	(up-compare-goal stored-id != 0)
=>
	(set-goal stored-id 0))

(defrule
	(up-compare-goal deer-luring != 3); else it's disabled
	(dropsite-min-distance deer-hunting < 32)
	(goal stored-id 0)
=>
	(up-get-point position-self point-x)
	(up-set-target-point point-x)
	(up-reset-search 1 1 1 1)
	(up-reset-filters)
	(up-filter-distance c: 7 c: 31)
	(up-find-remote c: deer c: 1)
	(up-set-target-object search-remote c: 0)
	(up-get-point position-object object-point-x)
	(up-get-object-data object-data-id stored-id)
	(set-goal deer-luring 1))

(defrule
	(goal deer-luring 1)
	(up-set-target-by-id g: stored-id)
=>
	(up-reset-search 1 1 1 1)
	(up-reset-filters)
	(up-find-local c: scout-unit c: 1)
	(up-set-target-object search-local c: 0)
	(up-get-point position-object saved-point-x)
	(up-set-target-by-id g: stored-id)
	(up-get-point position-self point-x)
	(up-get-point position-object object-point-x)
	(up-get-point-distance object-point-x point-x temporary-goal)
	(up-lerp-tiles object-point-x point-x c: -1)
	(up-target-point object-point-x action-move -1 -1))

(defrule
	(goal deer-luring 1)
	(up-set-target-by-id g: stored-id)
	(up-compare-goal object-point-x != -1)
	(up-compare-goal object-point-y != -1)
=>
	(up-target-point object-point-x action-move -1 -1)
	(up-get-object-data object-data-hitpoints temporary-goal4))

(defrule
	(goal deer-luring 1)
	(up-set-target-by-id g: stored-id)
	(goal temporary-goal4 0)
=>
	(set-goal stored-id 0))

(defrule
	(goal deer-luring 1)
	(up-compare-goal temporary-goal < 6); deer near TC
=>
;meh	(set-strategic-number sn-enable-boar-hunting 1)
	(up-get-point position-self point-x)
	(up-set-target-point point-x)
	(up-reset-search 1 1 1 1)
	(up-reset-filters)
	(up-filter-distance c: -1 c: 12)
	(up-find-local c: villager-class c: 4); vils on the deer
	(up-filter-distance c: -1 c: 7)
	(up-get-point position-self point-x)
	(up-find-remote c: deer c: 1)
	(up-set-target-by-id g: stored-id)
	(up-target-objects 0 action-default -1 -1)
	(up-get-search-state local-total)
	(set-goal stored-id 0))

(defrule
	(true)
=>
	(up-modify-sn sn-focus-player-number g:= temporary-goal2))
#end-if

