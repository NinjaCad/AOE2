(defrule
(or	(goal strategy drush)
(or	(goal strategy r-flush)
(or	(goal strategy krush)
(or	(population >= max-civ-pop)
(or	(and	(military-population >= 80)
		(strategic-number my-sn-military-superiority >= 1))
	(strategic-number my-sn-military-superiority >= 3))))))
=>
	(up-jump-rule 9))

(defrule
	(goal attacking yes)
	(unit-type-count trebuchet-set <= 0)
	(unit-type-count battering-ram-line < 2)
	(goal retreat yes)
	(up-projectile-detected projectile-town-center c:< 2500)
	(strategic-number my-sn-military-superiority <= 0)
=>
	(set-goal attacking no)
	(set-strategic-number sn-maximum-town-size 10)
	(set-strategic-number sn-percent-attack-soldiers 0)
	(up-retreat-now)
	(set-goal retreat no)
	(enable-timer retreat-timer 80)
	(chat-local-to-self "Retreating from enemy town-center."))

