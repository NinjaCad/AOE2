	(unit-type-count battering-ram-line < 2)
	(goal retreat yes)
	(up-projectile-detected projectile-bombard-tower c:< 2500)
	(strategic-number my-sn-military-superiority <= 0)
=>
	(set-goal attacking no)
	(set-strategic-number sn-maximum-town-size 10)
	(set-strategic-number sn-percent-attack-soldiers 0)
	(up-retreat-now)
