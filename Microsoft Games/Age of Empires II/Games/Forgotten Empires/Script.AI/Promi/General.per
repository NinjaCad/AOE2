#load-if-not-defined DIFFICULTY-HARDEST
(defrule
	(game-time < 180); emergency ; 3 mins
	(goal 511 -1); vils didn't meet yet
=>
	(up-jump-rule 1))
#else ; hardest
(defrule
	(game-time >= 1)
=>
	(cc-add-resource wood 75); to compensate for the house-bug + walking time, etc
	(cc-add-resource food 75); a bit of compensation for the needed scout/town-watch
	(disable-self))
#end-if

(defrule
	(goal landnomad yes)
	(game-time > 5)
	(up-gaia-type-count-total c: wood g:>= gl-wood-to-be-seen)
	(up-gaia-type-count-total c: wood >= 30); 30 trees found
	(building-type-count-total town-center <= 0)
	(building-type-count-total lumber-camp <= 0)
	(can-build lumber-camp)
=>
	(set-strategic-number sn-placement-zone-size 30)
	(set-goal landnomad 3)); Everything in rule below doesn't fit here
    

(defrule
	(goal landnomad 3); Rule above triggered and we want a lumber camp
	(can-build lumber-camp)
=>
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(up-reset-search 1 1 1 1)
	(up-reset-filters)
	(up-find-local c: villager-class c: 1)
	(up-set-target-object search-local c: 0)
	(up-get-point position-object point-x)
	(up-set-target-point point-x)
	(up-build place-point 0 c: lumber-camp)
	(set-strategic-number sn-wood-gatherer-percentage 100)
	(set-strategic-number sn-target-evaluation-ally-proximity 50)
	(set-strategic-number sn-maximum-food-drop-distance 20)
	(set-strategic-number sn-maximum-wood-drop-distance 25)
	(set-goal landnomad yes))


