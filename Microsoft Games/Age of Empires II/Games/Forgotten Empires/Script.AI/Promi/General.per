	(up-build place-point 0 c: town-center))


;===== UNIT BEHAVIOUR


(defrule
	(strategic-number sn-current-age >= castlea)
=>
	(up-jump-rule 8))
(defrule
	(strategic-number target-military-superiority >= 28)
=>
	(set-strategic-number my-sn-military-superiority 4))
(defrule
	(strategic-number target-military-superiority <= 27)
	(strategic-number target-military-superiority >= 20)
=>
	(set-strategic-number my-sn-military-superiority 3))
(defrule
	(strategic-number target-military-superiority <= 19)
	(strategic-number target-military-superiority >= 13)
=>
	(set-strategic-number my-sn-military-superiority 2))
(defrule
	(strategic-number target-military-superiority <= 12)
	(strategic-number target-military-superiority >= 7)
=>
	(set-strategic-number my-sn-military-superiority 1))
(defrule
	(strategic-number target-military-superiority <= 6)
	(strategic-number target-military-superiority >= -3)
=>
	(set-strategic-number my-sn-military-superiority 0))
(defrule
	(strategic-number target-military-superiority <= -4)
	(strategic-number target-military-superiority >= -10)
=>
	(set-strategic-number my-sn-military-superiority -1))
(defrule
	(strategic-number target-military-superiority <= -11)
	(strategic-number target-military-superiority >= -18)
=>
	(set-strategic-number my-sn-military-superiority -2))
(defrule
	(strategic-number target-military-superiority <= -19)
=>
	(set-strategic-number my-sn-military-superiority -3))

(defrule
	(strategic-number sn-current-age < castlea)
=>
	(up-jump-rule 8))
(defrule
	(strategic-number target-military-superiority >= 34)
=>
	(set-strategic-number my-sn-military-superiority 4))
(defrule
	(strategic-number target-military-superiority <= 33)
	(strategic-number target-military-superiority >= 23)
