(defrule
	(goal attacking yes)
	(unit-type-count cannon-galleon-line <= 0)
	(unit-type-count trebuchet-set <= 0)
	(unit-type-count battering-ram-line <= 0)
	(up-projectile-detected projectile-castle c:< 2500)
;	(strategic-number my-sn-military-superiority <= 3)
=>
	(set-goal attacking no)
	(up-reset-search 1 1 1 1)
	(up-filter-exclude -1 -1 -1 -1)
	(up-filter-range -1 -1 -1 -1)
	(up-filter-include cmdid-military -1 -1 -1)
	(up-find-local c: all-units-class c: 240)
;	(up-filter-include cmdid-monk -1 -1 -1)
;	(up-find-local c: all-units-class c: 240)
	(up-get-point position-self point-x)
	(up-set-target-point point-x)
	(up-target-point point-x action-move -1 stance-no-attack)
	(enable-timer resetnow 20)
	(chat-local-to-self "Retreating from enemy castle."))

(defrule
	(goal attacking yes)
	(unit-type-count trebuchet-set <= 0)
	(unit-type-count battering-ram-line < 2)
