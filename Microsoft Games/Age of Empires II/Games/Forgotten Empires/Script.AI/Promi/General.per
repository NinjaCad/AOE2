(defrule
	(goal attacking yes)
	(unit-type-count trebuchet-set <= 0)
	(unit-type-count battering-ram-line <= 0)
	(up-projectile-target projectile-watch-tower == ranged-units)
	(goal retreat yes)
	(up-projectile-detected projectile-watch-tower c:< 2500)
	(strategic-number my-sn-military-superiority <= 1)
=>
	(set-goal attacking no)
	(set-strategic-number sn-maximum-town-size 10)
	(set-strategic-number sn-percent-attack-soldiers 0)
	(up-retreat-now)
	(set-goal retreat no)
	(enable-timer retreat-timer 80)
	(chat-local-to-self "Retreating from enemy tower."))

(defrule
	(strategic-number sn-current-age < imperial)
	(strategic-number my-sn-military-superiority <= 3)
	(population <= max-civ-pop)
	(up-projectile-detected projectile-watch-tower c:< 2500)
	(up-projectile-target projectile-watch-tower == ranged-units)
;	(unit-type-count battering-ram-line <= 0)
	(goal attacking no)
=>
	(up-reset-search 1 1 1 1)
	(up-reset-filters)
	(up-get-point position-self position-self-x)
	(up-set-target-point position-self-x)
	(up-filter-include cmdid-military -1 -1 -1)
	(up-find-local c: ranged-units c: 240)
	(up-target-point position-self-x action-move -1 stance-no-attack)
	(enable-timer resetnow 9)
	(set-strategic-number sn-maximum-town-size 10)
	(chat-local-to-self "Retreat: Ranged units."))

(defrule
;(not	(enemy-buildings-in-town))
	(goal attacking no)
	(unit-type-count trebuchet-set <= 0)
	(unit-type-count battering-ram-line <= 1)
	(strategic-number sn-maximum-town-size >= 22)
(or	(up-projectile-detected projectile-castle c:< 2500)
(or	(up-projectile-detected projectile-bombard-tower c:< 2500)
	(up-projectile-detected projectile-town-center c:< 2500)))
	(up-projectile-target projectile-castle != siege-units)
	(up-projectile-target projectile-bombard-tower != siege-units)
	(up-projectile-target projectile-town-center != siege-units)
	(strategic-number my-sn-military-superiority <= 2)
=>
	(set-strategic-number sn-filter-under-attack 2)
	(set-strategic-number sn-maximum-town-size 10)
;	(up-retreat-to farm g: threat-target)
	(up-retreat-now)
;	(chat-local-to-self "Retreating from fortifications.")
)

(defrule
	(population <= del-civ-pop)
	(unit-type-count cannon-galleon-line <= 3)
(or	(or	(up-projectile-detected projectile-castle c:< 2500)
		(up-projectile-detected projectile-bombard-tower c:< 2500))
		(and	(and	(unit-type-count cannon-galleon-line <= 0)
				(warboat-count < 20))
				(up-projectile-detected projectile-watch-tower c:< 2500)))
	(up-projectile-target projectile-fortification == warships)
=>
	(set-strategic-number sn-percent-attack-boats 0)
	(up-retreat-to dock c: warships)
	(chat-local-to-self "Retreat: Warships."))

