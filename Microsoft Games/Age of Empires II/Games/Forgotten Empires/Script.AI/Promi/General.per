(defrule
	(goal reset yes)
	(goal retreat no)
	(goal attacking yes)
=>
	(disable-timer retreat-timer)
	(set-goal retreat yes)
	(set-goal reset no)
	(up-reset-unit c: -1)
	(chat-local-to-self "Resetting military units.")
;	(set-strategic-number sn-enemy-sighted-response-distance 10)
	(enable-timer reset-timer 8))

(defrule
	(timer-triggered reset-timer)
=>
	(disable-timer reset-timer)
	(set-goal reset yes))

(defrule
	(goal strategy drush)
	(up-compare-goal realdrushwaypoint >= 1)
	(up-compare-goal realdrushwaypoint <= 2)
	(goal selectdrushwaypoint 2)
	(timer-triggered resetnow)
=>
	(disable-timer resetnow)
	(set-goal reset no)
	(set-goal selectdrushwaypoint 1)
	(up-reset-unit c: -1)
	(up-set-attack-stance militiaman-line c: stance-aggressive)
	(chat-local-to-self "Resetting military units.")
;	(set-strategic-number sn-enemy-sighted-response-distance 10)
	(enable-timer reset-timer 3))

(defrule
	(goal strategy drush)
	(timer-triggered resetnow)
=>
	(disable-timer resetnow)
	(set-goal reset no)
	(up-reset-unit c: -1)
	(up-set-attack-stance militiaman-line c: stance-aggressive)
	(chat-local-to-self "Resetting military units.")
;	(set-strategic-number sn-enemy-sighted-response-distance 10)
	(enable-timer reset-timer 2))

(defrule
(not	(goal strategy drush))
	(timer-triggered resetnow)
=>
	(disable-timer resetnow)
	(set-goal reset no)
	(up-reset-unit c: -1)
	(chat-local-to-self "Resetting military units.")
	(up-set-attack-stance all-units-class c: stance-aggressive)
;	(set-strategic-number sn-enemy-sighted-response-distance 10)
	(enable-timer reset-timer 4))

(defrule
(or	(game-time > 1800)
	(unit-type-count 134 < 1))
=>
	(up-jump-rule 2))
(defrule
	(game-time < 1790)
	(unit-type-count 134 >= 2); Dead monk
=>
	(up-reset-search 1 1 1 1)
	(up-reset-filters)
	(up-filter-include -1 -1 731 -1)
	(up-find-local c: monk c: 240)
	(up-target-point 0 action-stop -1 -1))
(defrule
(or	(unit-type-count 134 < 2)
	(game-time > 1790))
	(goal underattack no)
=>
	(up-disband-group-type group-type-monk))

#load-if-not-defined DEATH-MATCH
(defrule
(or	(up-enemy-units-in-town < 5)
	(military-population < 5))
;(not	(town-under-attack))
=>
	(up-jump-rule 4))
(defrule
	(true)
=>
	(up-modify-goal temporary-goal2 s:= sn-focus-player-number))
(defrule
;(or
	(up-enemy-units-in-town >= 5)
;	(town-under-attack))
	(military-population >= 5)
	(goal gatherinside yes)
=>
	(up-modify-sn sn-focus-player-number g:= attacking-enemy)
	(up-get-fact enemy-units-in-town 0 math-goal2)
	(up-get-fact military-population 0 math-goal)
	(up-modify-goal math-goal g:- math-goal2))
(defrule
;(or
	(up-enemy-units-in-town >= 5)
;	(town-under-attack))
	(military-population >= 5)
	(up-compare-goal math-goal >= 0)
	(goal gatherinside yes)
=>
	(set-goal gatherinside no))
(defrule
	(true)
=>
	(up-modify-sn sn-focus-player-number g:= temporary-goal2))
(defrule
(or	(up-compare-goal threat-target != eagle-warrior)
	(unit-type-count eagle-warrior-line >= 2))
	(up-compare-goal threat-source != 910); wild animals
	(up-compare-goal threat-time < 2500)
(or	(goal threat-target villager-class)
(or	(goal threat-target infantry-units)
	(goal threat-target ranged-units)))
	(goal gatherinside yes)
=>
	(set-goal gatherinside no))
(defrule
	(timer-triggered embassy)
	(goal gatherinside yes)
=>
	(up-gather-inside c: stable c: 1)
	(up-gather-inside c: archery-range c: 1)
	(up-gather-inside c: barracks c: 1))
(defrule
(or	(goal attacking yes)
	(goal gatherinside no))
=>
	(up-gather-inside c: stable c: 0)
	(up-gather-inside c: archery-range c: 0)
	(up-gather-inside c: barracks c: 0)
	(set-goal gatherinside no)); in case i was just attacking
#end-if


(defrule
	(building-type-count-total town-center >= 1)
;(or	(enemy-buildings-in-town)
;	(and	(up-enemy-units-in-town > 1)
;		(or	(town-under-attack)
;			(goal enemy-goal drush))))
	(enemy-buildings-in-town)
;	(current-age == dark-age)
;	(goal retreat yes)
	(military-population <= 1)
	(strategic-number sn-total-number-explorers > 0)
=>
	(set-strategic-number sn-percent-civilian-explorers 0)
	(set-strategic-number sn-cap-civilian-explorers 0)
	(set-strategic-number sn-total-number-explorers 0)
	(set-strategic-number sn-number-explore-groups 0)
	(up-reset-scouts)
	(up-retreat-now)
;	(set-goal retreat no)
;	(enable-timer retreat-timer 80)
)

(defrule
	(goal nomad yes)
	(building-type-count-total town-center >= 1)
=>
	(up-reset-scouts)
	(disable-self))

(defrule
	(building-type-count-total town-center >= 1)
(nor	(enemy-buildings-in-town)
(or	(town-under-attack)
(or	(goal enemy-goal drush)
	(and	(up-enemy-units-in-town > 1)
		(goal attack no)))))
;	(current-age >= dark-age)
	(strategic-number sn-total-number-explorers == 0)
=>
	(set-strategic-number sn-percent-civilian-explorers 0)
;	(set-strategic-number sn-cap-civilian-explorers 0)
	(set-strategic-number sn-total-number-explorers 1)
	(set-strategic-number sn-number-explore-groups 1)
	(set-strategic-number sn-minimum-explore-group-size 1)
	(set-strategic-number sn-maximum-explore-group-size 1))

(defrule
	(game-time s:> sn-home-exploration-time)
(or	(up-compare-goal deer-luring <= 0)
	(up-compare-goal deer-luring >= 3))
(nor	(map-type islands)
	(map-type team-islands))
	(goal islands no)
	(players-building-count every-enemy <= 0)
	(military-population >= 1)
	(up-compare-goal milunits != no)
=>
	(chat-local-to-self "Searching for the closest enemy.")
	(up-send-scout group-type-land-explore scouting-type)
	(disable-self))

(defrule
(or	(and	(goal position-goal pocket)
		(goal milunits no))
	(and	(players-building-type-count any-ally market >= 1)
		(players-building-count every-enemy >= 1)))
	(game-time s:> sn-home-exploration-time)
(or	(up-compare-goal deer-luring <= 0)
	(up-compare-goal deer-luring >= 3))
	(military-population >= 1)
=>
	(chat-local-to-self "Exploring the nearest corner of the map.")
	(up-send-scout group-type-land-explore scout-corner)
	(disable-self))

(defrule
	(game-time < 1000)
	(goal Multiplayer yes)
	(players-building-count target-player >= 1)
=>
	(up-reset-search 1 1 1 1)
	(up-reset-filters)
	(up-get-point scouting-type point-x)
	(up-get-point position-target saved-point-x)); distance from the scouting point to the enemy

(defrule
(not	(goal strategy drush))
=>
	(up-jump-rule 1))
(defrule
	(timer-triggered scout)
	(game-time < 1080)
(not	(players-building-count every-enemy >= 1))
(or	(players-building-count every-enemy <= 0)
(or	(up-point-distance point-x saved-point-x >= 35)
	(goal drushtarget 0)))
	(military-population >= 1)
=>
	(chat-local-to-self "Drush: Rescouting in search of the closest enemy.")
	(up-send-scout group-type-land-explore scouting-type)
	(disable-timer scout)
	(enable-timer scout 75))

(defrule
(not	(goal strategy r-flush))
=>
	(up-jump-rule 1))
(defrule
	(timer-triggered scout)
	(game-time < 1080)
;	(unit-type-count-total archer-line >= 1)
(not	(players-building-count every-enemy >= 1))
(or	(players-building-count every-enemy <= 0)
	(up-point-distance point-x saved-point-x >= 35))
	(military-population >= 1)
=>
	(chat-local-to-self "r-flush: Rescouting in search of the closest enemy.")
	(up-send-scout group-type-land-explore scouting-type)
	(disable-timer scout)
	(enable-timer scout 75))

(defrule
(not	(goal strategy krush))
=>
	(up-jump-rule 1))
(defrule
	(timer-triggered scout)
	(game-time < 1080)
(not	(players-building-count every-enemy >= 1))
(or	(players-building-count every-enemy <= 0)
	(up-point-distance point-x saved-point-x >= 35))
	(military-population >= 1)
=>
	(chat-local-to-self "krush: Rescouting in search of the closest enemy.")
	(up-send-scout group-type-land-explore scouting-type)
