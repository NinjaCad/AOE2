;	(strategic-number sn-enable-boar-hunting != 2)
;	(dropsite-min-distance live-boar < 8)
;=>
;	(set-strategic-number sn-enable-boar-hunting 2); boar only
;	(chat-local-to-self "Boar hunting: 2"))
;(defrule
;(or	(dropsite-min-distance live-boar >= 32)
;	(and	(dropsite-min-distance live-boar >= 10)
;		(dropsite-min-distance boar-hunting < 10)))
;	(strategic-number sn-minimum-number-hunters != 1)
;	(strategic-number sn-enable-boar-hunting != 1)
;=>
;	(set-strategic-number sn-enable-boar-hunting 1); boar and deer
;	(chat-local-to-self "Boar hunting: 1"))

(defrule
	(goal boar-hunting-goal 2); hunt a second boar while still eating the first
	(up-remaining-boar-amount < 200)
(or	(dropsite-min-distance live-boar > 18)
	(up-remaining-boar-amount < 170))
	(dropsite-min-distance live-boar s:< sn-maximum-hunt-drop-distance)
=>
	(up-retask-gatherers food c: 1)
	(set-strategic-number sn-minimum-number-hunters 8); +1 hunter = lure 2nd boar
	(set-strategic-number sn-minimum-boar-hunt-group-size 0)
	(set-strategic-number sn-minimum-boar-lure-group-size 0)
	(set-goal boar-hunting-goal 3))
(defrule
	(goal boar-hunting-goal 3)
	(up-remaining-boar-amount == 65535); first boar finished
	(dropsite-min-distance live-boar s:< sn-maximum-hunt-drop-distance)
	(dropsite-min-distance live-boar > 8)
=>
	(set-strategic-number sn-minimum-number-hunters 1)
	(set-strategic-number sn-minimum-boar-hunt-group-size 0)
	(set-strategic-number sn-minimum-boar-lure-group-size 1)
	(set-goal boar-hunting-goal 1))
(defrule
	(goal boar-hunting-goal 3)
	(up-remaining-boar-amount < 50)
	(dropsite-min-distance live-boar s:> sn-maximum-hunt-drop-distance)
=>
	(set-strategic-number sn-minimum-number-hunters 0)
	(set-strategic-number sn-minimum-boar-hunt-group-size 0)
	(set-strategic-number sn-minimum-boar-lure-group-size 200); block again
	(set-goal boar-hunting-goal 4))
(defrule
	(unit-type-count villager-food > 7); won't get any assistance if everyone is chopping wood
	(dropsite-min-distance live-boar < 32)
	(up-compare-goal boar-hunting-goal >= 4)
	(unit-type-count villager-hunter == 0)
=>
	(up-retask-gatherers food c: 1)
	(set-strategic-number sn-minimum-number-hunters 1)
	(set-strategic-number sn-enable-boar-hunting 2)
	(set-strategic-number sn-minimum-boar-lure-group-size 0)
	(set-goal boar-hunting-goal 1))
(defrule
	(research-completed ri-loom)
	(unit-type-count villager >= 12)
(or	(unit-type-count villager >= 18)
	(and	(cc-players-unit-type-count 0 48 == 0); no boar on map
		(cc-players-unit-type-count 0 822 == 0)))
	(up-compare-goal boar-hunting-goal < 5)
	(dropsite-min-distance live-boar >= 32)
=>
	(set-strategic-number sn-enable-boar-hunting 1); enable deer hunting too
	(set-strategic-number sn-minimum-number-hunters 0)
	(set-goal boar-hunting-goal 5))
(defrule
	(current-age == dark-age)
	(unit-type-count villager >= 13)
(or	(dropsite-min-distance deer-hunting < 7)
	(and	(dropsite-min-distance boar-hunting < 7)
		(dropsite-min-distance live-boar >= 7)))
;	(dropsite-min-distance live-boar >= 32)
	(unit-type-count villager-farmer >= 1)
	(strategic-number sn-enable-boar-hunting == 1)
	(strategic-number sn-minimum-number-hunters < 4)
=>
	(up-retask-gatherers 50 c: 1)
	(up-modify-sn sn-minimum-number-hunters c:+ 1)
	(chat-local-to-self "Retasking farmer to hunt.")); retasking one farmer to hunt
(defrule
	(current-age == dark-age)
	(unit-type-count villager >= 18)
	(goal boar-hunting-goal 5)
	(dropsite-min-distance deer-hunting < 30)
	(dropsite-min-distance live-boar >= 32)
	(unit-type-count villager-forager >= 4)
	(strategic-number sn-enable-boar-hunting == 1)
	(strategic-number sn-minimum-number-hunters < 4)
=>
	(up-retask-gatherers 907 c: 1)
	(up-modify-sn sn-minimum-number-hunters c:+ 1)
	(chat-local-to-self "Retasking forager to hunt.")); retasking one forager to hunt
(defrule
	(current-age == dark-age)
	(unit-type-count villager >= 13)
(or	(dropsite-min-distance deer-hunting < 7)
	(and	(dropsite-min-distance boar-hunting < 7)
		(dropsite-min-distance live-boar >= 7)))
;	(dropsite-min-distance live-boar >= 32)
	(unit-type-count villager-forager >= 3)
	(strategic-number sn-enable-boar-hunting == 1)
	(strategic-number sn-minimum-number-hunters < 4)
=>
	(up-retask-gatherers 907 c: 1)
	(up-modify-sn sn-minimum-number-hunters c:+ 1)
	(chat-local-to-self "Retasking forager to hunt.")); retasking one forager to hunt
