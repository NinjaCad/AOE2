(defrule
	(unit-type-count villager > 7)
	(dropsite-min-distance live-boar < 32)
=>
	(set-strategic-number sn-maximum-hunt-drop-distance 32)
;	(set-strategic-number sn-maximum-food-drop-distance 32)
)
;(defrule
;	(dropsite-min-distance live-boar >= 32)
;(or	(and	(food-amount >= 50)
;		(up-pending-objects c: villager >= 1))
;(or		(food-amount >= 100)
;		(up-pending-objects c: villager >= 2))); for aztec forced drop
;=>
;	(set-strategic-number sn-enable-boar-hunting 1))
(defrule
	(research-completed ri-loom)
	(dropsite-min-distance live-boar < 32)
	(unit-type-count villager-food >= 1)
=>
	(set-strategic-number sn-enable-boar-hunting 2); boars only
	(disable-self))
(defrule
	(strategic-number sn-enable-boar-hunting <= 0)
	(unit-type-count-total villager > 7)
=>
	(set-strategic-number sn-enable-boar-hunting 1); boar and deer
	(disable-self))
(defrule
	(up-compare-goal boar-hunting-goal < 3); no hunting available
	(dropsite-min-distance live-boar >= 32)
	(dropsite-min-distance deer-hunting >= 32)
	(unit-type-count-total villager >= 10)
=>
	(up-get-player-fact my-player-number game-time 0 math-goal)
;test	(up-modify-sn sn-home-exploration-time g:< math-goal)
	(up-modify-sn sn-home-exploration-time c:+ 90)
	(disable-self))
(defrule
	(research-completed ri-loom)
	(unit-type-count villager > 7)
(or	(building-type-count-total mill == 0)
	(up-object-type-count-total c: villager > 10))
	(dropsite-min-distance live-boar < 32)
	(up-compare-goal boar-hunting-goal < 1)
	(unit-type-count-total villager-hunter == 0)
=>
	(set-strategic-number sn-maximum-hunt-drop-distance 32)
	(set-strategic-number sn-minimum-number-hunters 1)
	(up-retask-gatherers food c: 1)
	(set-strategic-number sn-minimum-boar-lure-group-size 0); may block hunting if too high
	(set-strategic-number sn-minimum-boar-hunt-group-size 0)
	(set-goal boar-hunting-goal 1))
(defrule
(or	(goal boar-hunting-goal 1)
	(dropsite-min-distance live-boar < 7)); 2nd boar+
	(unit-type-count villager-hunter >= 1)
(or	(strategic-number sn-minimum-number-hunters < 7)
	(strategic-number sn-minimum-boar-hunt-group-size < 6))
	(dropsite-min-distance live-boar < 8)
=>
	(set-goal boar-hunting-goal 2)
	(set-strategic-number sn-minimum-boar-hunt-group-size 6); #vils to kill the boar
	(set-strategic-number sn-minimum-number-hunters 7); #hunters to harvest the boar
	(set-strategic-number sn-minimum-boar-lure-group-size 999); blocked
	(up-request-hunters c: 6))

