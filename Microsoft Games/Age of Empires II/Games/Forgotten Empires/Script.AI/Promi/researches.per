	(disable-self))
#end-if
#load-if-defined SARACEN-CIV
(defrule
(or	(unit-type-count-total camel-line >= 5)
	(unit-type-count-total my-unique-unit-line >= 5))
	(can-research my-unique-research)
=>
	(research my-unique-research)
	(set-goal researchplan yes))
#end-if
#load-if-defined VIKING-CIV
(defrule
	(up-research-status c: ri-champion >= research-pending)
	(goal researchplan no)
=>
	(set-goal researchplan yes))
#end-if
(defrule ; just to make sure
	(strategic-number sn-current-age >= imperial)
(or	(or	(unit-type-count-total trade-cart >= 45)
		(unit-type-count-total trade-cog >= 45))
	(and	(and	(wood-amount >= 4000)
			(food-amount >= 4000))
		(gold-amount >= 4000)))
	(goal researchplan no)
=>
	(set-goal researchplan yes))
;=============================================================
;
; Economic research
;
;=============================================================
;=============================================================
; Villager upgrades
;=============================================================
(defrule
	(up-compare-goal strategy != r-flush)
	(can-research ri-wheel-barrow)
=>
	(research ri-wheel-barrow))
;=============================================================
(defrule
	(up-compare-goal strategy == r-flush)
	(building-type-count-total archery-range >= 2)
	(up-compare-goal escrowing == 0)
	(can-research ri-wheel-barrow)
=>
	(research ri-wheel-barrow))
;=============================================================
(defrule
(or	(building-type-count town-center <= 1)
(or	(not	(research-available ri-hand-cart))
(or	(goal underattack yes)
(or	(civilian-population >= up-max-civ)
(or	(up-research-status c: imperial-age >= research-pending)
	(up-research-status c: ri-hand-cart >= research-pending))))))
=>
	(up-jump-rule 2))
(defrule
(or	(players-military-population every-enemy < 2)
	(strategic-number my-sn-military-superiority >= 1))
(or	(goal dreitc yes)
	(strategic-number my-sn-military-superiority >= 2))
	(unit-type-count-total villager >= 55)
	(gold-amount >= 200)
	(food-amount < 300)
	(food-amount >= 100)
	(can-buy-commodity food)
=>
	(set-escrow-percentage wood 100)
	(buy-commodity food)
	(set-goal escrowing ri-hand-cart)
	(chat-local-to-self "Buying food for hand-cart."))
(defrule
(or	(players-military-population every-enemy < 2)
	(strategic-number my-sn-military-superiority >= 1))
(or	(goal dreitc yes)
	(strategic-number my-sn-military-superiority >= 2))
	(unit-type-count-total villager >= 55)
	(gold-amount >= 200)
	(food-amount >= 300)
	(wood-amount >= 100)
	(wood-amount < 200)
	(can-buy-commodity wood)
=>
	(set-escrow-percentage wood 100)
	(buy-commodity wood)
	(set-goal escrowing ri-hand-cart)
	(chat-local-to-self "Buying wood for hand-cart."))
(defrule
	(goal escrowing ri-hand-cart)
	(escrow-amount wood >= 200)
=>
	(set-escrow-percentage wood 0))
(defrule
	(goal escrowing ri-hand-cart)
(or	(goal underattack yes)
	(strategic-number my-sn-military-superiority <= -1))
=>
	(release-escrow wood)
	(release-escrow food)
	(set-escrow-percentage wood 0)
	(set-escrow-percentage food 0)
	(set-goal escrowing 0))
(defrule
	(goal escrowing ri-hand-cart)
	(can-research-with-escrow ri-hand-cart)
=>
	(release-escrow wood)
	(release-escrow food)
	(set-escrow-percentage wood 0)
	(set-escrow-percentage food 0)
	(set-goal escrowing 0)
	(research ri-hand-cart)
	(chat-local-to-self "Researching hand-cart."))
(defrule
(or	(goal dreitc yes)
(or	(unit-type-count-total villager >= 55)
	(strategic-number my-sn-military-superiority >= 1)))
	(can-research ri-hand-cart)
=>
	(research ri-hand-cart)
	(chat-local-to-self "Researching hand-cart."))
;=============================================================
; Lumber upgrades
;=============================================================
(defrule
(or	(strategic-number sn-current-age >= fcastlea)
(or	(food-amount >= 900)
	(and	(goal enemy-goal flush)
		(and	(strategic-number my-sn-military-superiority >= 0)
			(building-type-count-total blacksmith >= 1)))))
	(can-research axe-1)
=>
	(research axe-1))
;=============================================================
(defrule
	(goal strategy r-flush)
;	(building-type-count-total blacksmith >= 1)
;	(building-type-count-total archery-range >= 2)
	(can-research axe-1)
=>
	(research axe-1))
;=============================================================
(defrule
(or	(unit-type-count-total villager >= 45)
(or	(goal dreitc yes)
	(strategic-number my-sn-military-superiority >= 1)))
	(can-research axe-2)
=>
	(research axe-2))
;=============================================================
; Farm upgrades
;=============================================================
(defrule
	(up-research-status c: axe-1 >= research-pending)
(or	(strategic-number sn-current-age >= fcastlea)
(or	(food-amount >= 875)
	(and	(goal enemy-goal flush)
		(and	(strategic-number my-sn-military-superiority >= 0)
			(building-type-count-total blacksmith >= 1)))))
	(can-research farm-1)
=>
	(research farm-1))
;=============================================================
(defrule
	(goal strategy r-flush)
	(up-research-status c: axe-1 >= research-pending)
	(building-type-count-total blacksmith >= 1)
	(building-type-count-total archery-range >= 2)
	(can-research farm-1)
=>
	(research farm-1))
;=============================================================
(defrule
(or	(unit-type-count-total villager >= 45)
(or	(goal dreitc yes)
	(strategic-number my-sn-military-superiority >= 1)))
	(can-research farm-2)
=>
	(research farm-2))
;=============================================================
; Mining
;=============================================================
(defrule
	(up-research-status c: farm-2 >= research-pending)
(or	(unit-type-count-total 579 >= 1) ;Male gold miner
	(unit-type-count-total 581 >= 1)) ;female gold miner
(or	(unit-type-count-total villager >= 48)
(or	(goal dreitc yes)
	(strategic-number my-sn-military-superiority >= 2)))
(or	(goal milunits no)
(or	(goal e-skirm yes)
	(gold-amount < 160)))
	(can-research mine-1)
=>
	(research mine-1))
;=============================================================
(defrule
	(building-type-count dock >= 1)
	(goal enemy-boats yes)
	(strategic-number sn-current-age >= fcastlea)
(or	(unit-type-count-total 579 >= 1) ;Male gold miner
	(unit-type-count-total 581 >= 1)) ;female gold miner
	(can-research mine-1)
=>
	(research mine-1))
;=============================================================
(defrule
(or	(goal strategy r-flush)
	(goal strategy krush))
	(up-research-status c: axe-1 >= research-pending)
	(building-type-count-total blacksmith >= 1)
(or	(building-type-count-total archery-range >= 2)
	(building-type-count-total stable >= 2))
	(can-research mine-1)
=>
	(research mine-1))
;=============================================================
(defrule
	(goal e-skirm yes)
	(goal dreitc yes)
(or	(unit-type-count-total 124 >= 2) ;Male stone-miner
	(unit-type-count-total 220 >= 2)) ;female stone-miner
(or	(strategic-number sn-current-age >= imperial)
(or	(goal milunits no)
	(strategic-number my-sn-military-superiority >= 1))); 1 = test (barely any costs though)
	(can-research mine-2)
=>
	(research mine-2))
;=============================================================
(defrule
(or	(goal e-skirm yes)
(or	(goal milunits no)
(or	(strategic-number my-sn-military-superiority >= 2)
(or	(strategic-number sn-current-age >= imperial)
	(and	(strategic-number my-sn-military-superiority >= 0)
		(gold-amount < 100))))))
(or	(unit-type-count-total 579 >= 1) ;Male gold miner
	(unit-type-count-total 581 >= 1)) ;female gold miner
	(can-research mine-3)
=>
	(research mine-3))
;=============================================================
(defrule
	(up-research-status c: ri-hand-cart >= research-pending)
	(building-type-count castle <= 1)
	(stone-amount < 500)
	(goal e-skirm yes)
	(goal dreitc yes)
	(goal defend no)
	(strategic-number my-sn-military-superiority >= 1)
(or	(unit-type-count-total 124 >= 2) ;Male stone-miner
	(unit-type-count-total 220 >= 2)) ;female stone-miner
	(can-research mine-4)
=>
	(research mine-4))
;=============================================================
; Teams
;=============================================================
#load-if-not-defined WONDER-RACE
(defrule
	(goal underattack no)
	(player-in-game any-ally)
(or	(unit-type-count-total trade-cart > 8)
(or	(unit-type-count-total trade-cog > 6)
	(and	(unit-type-count-total trade-cart > 4)
		(strategic-number sn-current-age >= imperial))))
	(can-research ri-cartography)
=>
	(research ri-cartography)
	(chat-to-player my-player-number "Researching cartography."))
;=============================================================
(defrule
	(goal underattack no)
	(player-in-game any-ally)
(or	(unit-type-count-total trade-cart > 3)
	(unit-type-count-total trade-cog > 3))
	(can-research ri-caravan)
=>
	(research ri-caravan)
	(chat-to-player my-player-number "Researching caravan."))
;=============================================================
(defrule
(or	(taunt-detected any-ally 3)
(or	(taunt-detected any-ally 4)
(or	(taunt-detected any-ally 5)
	(taunt-detected any-ally 6))))
	(player-in-game any-ally)
	(strategic-number sn-current-age >= imperial)
	(can-research ri-coinage)
=>
	(research ri-coinage)
	(chat-to-player my-player-number "Researching coinage.")
	(acknowledge-taunt this-any-ally 3)
	(acknowledge-taunt this-any-ally 4)
	(acknowledge-taunt this-any-ally 5)
	(acknowledge-taunt this-any-ally 6))
(defrule
(or	(wood-amount > 2000)
(or	(food-amount > 2000)
	(gold-amount > 2000)))
(or	(up-allied-resource-amount any-ally wood < 1200)
(or	(up-allied-resource-amount any-ally food < 1200)
	(up-allied-resource-amount any-ally gold < 1200)))
;	(goal underattack no)
(or	(population > del-civ-pop)
	(strategic-number sn-current-age >= imperial))
	(player-in-game every-ally)
	(can-research ri-coinage)
=>
	(research ri-coinage)
;	(chat-to-player my-player-number "Researching coinage.")
)
;=============================================================
(defrule
	(goal underattack no)
	(player-in-game any-ally)
(or	(population > up-max-civ)
	(strategic-number sn-current-age >= imperial))
	(can-research ri-banking)
=>
	(research ri-banking)
	(chat-to-player my-player-number "Researching banking."))
#end-if
;============================================================
; Buildings defense
;============================================================
(defrule
(or	(and	(strategic-number my-sn-military-superiority <= -1)
		(goal defend yes))
(or	(town-under-attack)
	(goal researchplan yes)))
        (building-type-count castle >= 3)
	(can-research ri-murder-holes)
=>
	(research ri-murder-holes))
;============================================================
(defrule
(or	(and	(building-type-count castle > 0)
		(town-under-attack))
(or	(unit-type-count-total skirmisher-line >= 14)
(or	(unit-type-count-total ranged-units >= 9)
(or	(unit-type-count-total cavalry-archer-units >= 9)
(or	(unit-type-count-total galley-line >= 6)
	(goal researchplan yes))))))
	(can-research ri-ballistics)
=>
	(research ri-ballistics))
;============================================================
