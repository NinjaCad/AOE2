;=============================================================
; Pike upgrades
;=============================================================
(defrule
(or	(goal strategy krush)
(or	(goal underattack yes)
(or	(not	(research-available ri-pikeman))
	(building-type-count barracks <= 0))))
=>
	(up-jump-rule 6))
(defrule
(nor	(and	(goal enemy-goal rush)
		(or	(players-building-type-count focus-player stable >= 2)
			(players-unit-type-count focus-player knight-line >= 8)))
(or	(players-unit-type-count focus-player knight-line >= 14)
	(players-unit-type-count focus-player scout-cavalry-line >= 20)))
=>
	(up-jump-rule 5))
(defrule
(or	(and	(goal enemy-goal rush)
		(or	(players-building-type-count focus-player stable >= 2)
			(players-unit-type-count focus-player knight-line >= 8)))
(or	(players-unit-type-count focus-player knight-line >= 14)
	(players-unit-type-count focus-player scout-cavalry-line >= 20)))
	(building-type-count barracks >= 1)
=>
	(set-escrow-percentage food 100)
	(set-escrow-percentage gold 100)
	(chat-to-player my-player-number "Starting pike-escrow.")
	(set-goal escrowing ri-pikeman)
	(disable-self))
(defrule
(or	(unit-type-count-total spearman-line >= 2)
(or	(goal researchplan yes)
	(cc-players-unit-type-count 0 gold-mine < 4)))
	(research-available ri-pikeman)
	(gold-amount >= 200)
	(food-amount < 215)
	(can-buy-commodity food)
=>
	(set-escrow-percentage food 100)
	(set-escrow-percentage gold 100)
	(buy-commodity food)
	(set-goal escrowing ri-pikeman)
	(chat-local-to-self "Buying food for ri-pikeman."))
(defrule
(or	(unit-type-count-total spearman-line >= 2)
(or	(goal researchplan yes)
	(cc-players-unit-type-count 0 gold-mine < 4)))
	(research-available ri-pikeman)
	(food-amount >= 215)
	(wood-amount >= 200)
	(gold-amount < 90)
	(can-sell-commodity wood)
=>
	(set-escrow-percentage food 100)
	(set-escrow-percentage gold 100)
	(sell-commodity wood)
	(set-goal escrowing ri-pikeman)
	(chat-local-to-self "Selling wood for ri-pikeman."))
(defrule
	(goal escrowing ri-pikeman)
	(escrow-amount food >= 215)
=>
	(set-escrow-percentage food 0))
(defrule
	(goal escrowing ri-pikeman)
	(escrow-amount gold >= 90)
=>
	(set-escrow-percentage gold 0))
(defrule
	(goal escrowing ri-pikeman)
(or	(building-type-count barracks <= 0)
	(goal underattack yes))
=>
	(release-escrow gold)
	(release-escrow food)
	(set-escrow-percentage gold 0)
	(set-escrow-percentage food 0)
	(set-goal escrowing 0))
(defrule
	(goal escrowing ri-pikeman)
	(can-research-with-escrow ri-pikeman)
=>
	(chat-local-to-self "Researching pikes.")
	(release-escrow gold)
	(set-escrow-percentage gold 0)
	(release-escrow food)
	(set-escrow-percentage food 0)
	(set-goal escrowing 0)
	(research ri-pikeman))
(defrule
(or	(unit-type-count-total spearman-line >= 2)
(or	(goal researchplan yes)
	(cc-players-unit-type-count 0 gold-mine < 4)))
	(can-research ri-pikeman)
