(defrule
(or	(goal dreitc yes)
	(and	(strategic-number my-sn-military-superiority <= -1)
		(not	(goal position-goal pocket))))
(or	(unit-type-count-total skirmisher-line >= 5)
(or	(strategic-number archers >= 5)
(or	(goal researchplan yes)
	(cc-players-unit-type-count 0 gold-mine < 5))))
	(can-research ri-elite-skirmisher)
=>
