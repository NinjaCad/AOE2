;=============================================================
;
; Age advancement
;
;=============================================================
(defrule
(or	(food-amount >= 800)
(or	(unit-type-count-total villager >= darkvils)
(or	(up-compare-goal enemy-goal != 0)
	(players-current-age any-enemy >= feudal-age))))
	(can-research-with-escrow feudal-age)
=>
	(set-strategic-number sn-enable-boar-hunting 1)
	(release-escrow food)
	(set-escrow-percentage food 0)
	(research feudal-age)
;	(set-goal escrowing 0)
	(chat-to-player every-ally "I am advancing to the Feudal Age.")
	(chat-to-player my-player-number "I am advancing to the Feudal Age.")
	(set-strategic-number sn-current-age dfeudal)
	(set-strategic-number sn-maximum-town-size 10))
(defrule
	(goal strategy r-flush)
	(can-research-with-escrow feudal-age)
=>
	(set-strategic-number sn-enable-boar-hunting 1)
	(release-escrow food)
	(set-escrow-percentage food 0)
	(research feudal-age)
	(chat-to-player every-ally "I am advancing to the Feudal Age.")
	(chat-to-player my-player-number "I am advancing to the Feudal Age.")
	(set-strategic-number sn-current-age dfeudal)
	(set-strategic-number sn-maximum-town-size 10))
;=============================================================
(defrule
	(goal strategy usual)
	(strategic-number sn-current-age == feudal)
	(strategic-number my-sn-military-superiority >= 0)
(or	(players-current-age target-player >= castle-age)
	(strategic-number my-sn-military-superiority >= 1))
(or	(unit-type-count villager-gold >= 4)
	(unit-type-count-total trade-cart >= 8))
	(goal underattack no)
	(goal escrowing 0)
	(research-available castle-age)
=>
	(set-escrow-percentage food 100)
	(set-escrow-percentage gold 100)
	(set-goal escrowing castlea))
(defrule
	(goal strategy usual)
	(strategic-number sn-current-age == feudal)
	(strategic-number my-sn-military-superiority >= 0)
	(strategic-number target-civilian-superiority >= 3)
	(goal attacking no)
;	(unit-type-count villager-food >= 8)
(or	(gold-amount >= 100)
(or	(unit-type-count villager-gold >= 4)
	(unit-type-count-total trade-cart >= 8)))
	(goal underattack no)
	(goal escrowing 0)
	(research-available castle-age)
=>
	(set-escrow-percentage food 100)
	(set-escrow-percentage gold 100)
	(set-goal escrowing castlea))
(defrule
;	(goal strategy r-flush)
	(strategic-number sn-current-age == feudal)
	(strategic-number my-sn-military-superiority >= 3)
(or	(unit-type-count villager-gold >= 6)
(or	(unit-type-count-total trade-cart >= 12)
	(up-compare-goal gl-relics >= 6)))
	(goal underattack no)
	(goal escrowing 0)
	(research-available castle-age)
=>
	(set-escrow-percentage food 100)
	(set-escrow-percentage gold 100)
	(set-goal escrowing castlea))
(defrule
;	(goal strategy r-flush)
	(strategic-number sn-current-age == feudal)
	(strategic-number my-sn-military-superiority >= 4)
(or	(unit-type-count villager-gold >= 4)
(or	(unit-type-count-total trade-cart >= 8)
	(up-compare-goal gl-relics >= 4)))
	(goal underattack no)
	(goal escrowing 0)
	(research-available castle-age)
=>
	(set-escrow-percentage food 70)
	(set-escrow-percentage gold 70)
	(set-goal escrowing castlea))
(defrule
;	(goal strategy r-flush)
	(strategic-number sn-current-age == feudal)
	(strategic-number my-sn-military-superiority >= 1)
(or	(food-amount >= 700)
	(and	(food-amount >= 500)
		(gold-amount >= 150)))
(or	(unit-type-count villager-gold >= 4)
	(unit-type-count-total trade-cart >= 8))
	(goal underattack no)
	(goal escrowing 0)
	(research-available castle-age)
=>
	(set-escrow-percentage food 100)
	(set-escrow-percentage gold 100)
	(set-goal escrowing castlea))
(defrule
	(goal escrowing castlea)
	(escrow-amount food >= 800)
=>
	(set-escrow-percentage food 0))
(defrule
	(goal escrowing castlea)
	(escrow-amount gold >= 200)
=>
	(set-escrow-percentage gold 0))
(defrule
(or	(goal strategy usual)
	(goal underattack yes))
	(goal escrowing castlea)
=>
	(release-escrow food)
	(release-escrow gold)
	(set-escrow-percentage food 0)
	(set-escrow-percentage gold 0)
	(set-goal escrowing 0))
(defrule
	(goal escrowing castlea)
	(can-research-with-escrow castle-age)
=>
	(release-escrow food)
	(release-escrow gold)
	(set-escrow-percentage food 0)
	(set-escrow-percentage gold 0)
	(research castle-age)
	(set-goal escrowing 0)
	(chat-to-player every-ally "I am advancing to the Castle Age.")
	(chat-to-player my-player-number "I am advancing to the Castle Age.")
	(set-strategic-number sn-current-age fcastlea)
	(set-strategic-number sn-maximum-town-size 10))
(defrule
	(can-research castle-age)
=>
	(research castle-age)
	(chat-to-player every-ally "I am advancing to the Castle Age.")
	(chat-to-player my-player-number "I am advancing to the Castle Age.")
	(set-strategic-number sn-current-age fcastlea)
	(set-strategic-number sn-maximum-town-size 10))
;=============================================================
(defrule
	(strategic-number sn-current-age == castlea)
	(strategic-number target-civilian-superiority >= 25); test
(or	(unit-type-count villager-gold >= 8)
(or	(unit-type-count-total trade-cart >= 15)
	(up-compare-goal gl-relics >= 5)))
	(up-enemy-units-in-town < 5)
	(goal underattack no)
	(goal escrowing 0)
	(population >= up-max-civ)
	(research-available imperial-age)
=>
	(set-escrow-percentage food 100)
	(set-escrow-percentage gold 100)
	(set-goal escrowing imperial-age))
(defrule
	(strategic-number sn-current-age == castlea)
	(strategic-number my-sn-military-superiority >= 2)
	(goal underattack no)
	(players-current-age any-enemy >= imperial-age)
(or	(unit-type-count villager-gold >= 7)
(or	(unit-type-count-total trade-cart >= 14)
	(up-compare-goal gl-relics >= 5)))
	(goal escrowing 0)
	(population >= up-max-civ)
	(research-available imperial-age)
=>
	(set-escrow-percentage food 80)
	(set-escrow-percentage gold 80)
	(set-goal escrowing imperial-age))
(defrule
	(strategic-number sn-current-age == castlea)
	(strategic-number my-sn-military-superiority >= 2)
	(goal strategy usual)
	(goal underattack no)
(or	(unit-type-count villager-gold >= 7)
(or	(unit-type-count-total trade-cart >= 14)
	(up-compare-goal gl-relics >= 5)))
	(goal escrowing 0)
	(population >= up-max-civ)
	(research-available imperial-age)
=>
	(set-escrow-percentage food 80)
	(set-escrow-percentage gold 80)
	(set-goal escrowing imperial-age))
(defrule
	(strategic-number sn-current-age == castlea)
	(strategic-number my-sn-military-superiority >= 3)
;	(goal strategy usual)
	(goal underattack no)
(or	(unit-type-count villager-gold >= 7)
(or	(unit-type-count-total trade-cart >= 14)
	(up-compare-goal gl-relics >= 5)))
	(goal escrowing 0)
	(population >= up-max-civ)
	(research-available imperial-age)
=>
	(set-escrow-percentage food 70)
	(set-escrow-percentage gold 70)
	(set-goal escrowing imperial-age))
(defrule
	(strategic-number sn-current-age == castlea)
	(goal underattack no)
(or	(strategic-number my-sn-military-superiority >= 1)
	(up-enemy-units-in-town < 5))
(or	(unit-type-count villager-gold >= 8)
(or	(unit-type-count-total trade-cart >= 15)
	(up-compare-goal gl-relics >= 5)))
	(goal escrowing 0)
	(population >= 200)
	(research-available imperial-age)
=>
	(set-escrow-percentage food 80)
	(set-escrow-percentage gold 80)
	(set-goal escrowing imperial-age))
(defrule
	(strategic-number sn-current-age == castlea)
	(goal underattack no)
(or	(unit-type-count villager-gold >= 8)
(or	(unit-type-count-total trade-cart >= 15)
	(up-compare-goal gl-relics >= 5)))
	(goal milunits no)
	(population >= up-max-civ)
	(goal escrowing 0)
	(research-available imperial-age)
=>
	(set-escrow-percentage food 80)
	(set-escrow-percentage gold 80)
	(set-goal escrowing imperial-age))
(defrule
	(goal escrowing imperial-age)
	(escrow-amount food >= imp-food)
=>
	(set-escrow-percentage food 0))
(defrule
	(goal escrowing imperial-age)
	(escrow-amount gold >= imp-gold)
=>
	(set-escrow-percentage gold 0))
(defrule
	(goal underattack yes)
	(strategic-number my-sn-military-superiority <= 1)
	(goal escrowing imperial-age)
=>
	(release-escrow food)
	(release-escrow gold)
	(set-escrow-percentage food 0)
	(set-escrow-percentage gold 0)
	(set-goal escrowing 0))
(defrule
	(goal escrowing imperial-age)
	(can-research-with-escrow imperial-age)
=>
	(release-escrow food)
	(release-escrow gold)
	(set-escrow-percentage food 0)
	(set-escrow-percentage gold 0)
	(set-goal escrowing 0)
	(research imperial-age)
	(chat-to-player every-ally "I am advancing to the Imperial Age.")
	(chat-to-player my-player-number "I am advancing to the Imperial Age.")
	(set-strategic-number sn-current-age imperial)
	(set-strategic-number sn-maximum-town-size 10))
(defrule
	(can-research imperial-age)
=>
	(research imperial-age)
	(chat-to-player every-ally "I am advancing to the Imperial Age.")
	(chat-to-player my-player-number "I am advancing to the Imperial Age.")
	(set-strategic-number sn-current-age imperial)
	(set-strategic-number sn-maximum-town-size 10))
;=============================================================
; Unique upgrades
;=============================================================
#load-if-not-defined HUN-CIV

(defrule
(or	(unit-type-count-total my-unique-unit-line >= 4)
(or	(unit-type-count-total huskarl-set >= 4)
(or	(gold-amount >= 2900)
	(and	(or	(population >= max-civ-pop)
			(population >= 190))
		(gold-amount >= 1900)))))
	(can-research my-unique-unit-upgrade)
=>
	(research my-unique-unit-upgrade)
	(set-goal e-cata yes))
(defrule
(or	(unit-type-count-total trade-cart >= 25)
	(unit-type-count-total trade-cog >= 25))
	(can-research my-unique-unit-upgrade)
=>
	(research my-unique-unit-upgrade)
	(set-goal e-cata yes))

(defrule
(or	(unit-type-count-total trade-cart >= 25)
(or	(unit-type-count-total trade-cog >= 25)
(or	(unit-type-count-total my-unique-unit-line >= 4)
(or	(unit-type-count-total huskarl-set >= 4)
(or	(gold-amount >= 2900)
	(and	(population >= up-max-civ)
		(gold-amount >= 1900)))))))
	(goal uugoal no)
=>
	(set-goal uugoal yes))

#end-if

