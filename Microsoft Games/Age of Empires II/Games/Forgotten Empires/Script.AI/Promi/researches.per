(or	(unit-type-count-total scout-cavalry-line >= 4)
	(cc-players-unit-type-count 0 gold-mine < 3))
	(can-research ri-hussar)
=>
	(research ri-hussar))
;=============================================================
(defrule
(or	(strategic-number cavalry > 15)
(or	(unit-type-count-total camel-line > 7)
	(players-unit-type-count any-enemy cavalry-archer-units >= 11)))
	(unit-type-count-total camel-line > 4)
	(can-research ri-heavy-camel)
=>
	(research ri-heavy-camel))
;=============================================================
; Archer upgrades
;=============================================================
(defrule
(or	(unit-type-count villager-gold >= 2)
(or	(unit-type-count-total trade-cart >= 5)
	(up-compare-goal gl-relics >= 3)))
	(goal underattack no)
	(unit-type-count-total archer-line >= 14)
	(goal escrowing 0)
	(research-available ri-crossbow)
=>
	(set-escrow-percentage food 100)
	(set-escrow-percentage gold 100)
	(set-goal escrowing ri-crossbow))
(defrule
	(goal escrowing ri-crossbow)
	(escrow-amount food >= 125)
=>
	(set-escrow-percentage food 0))
(defrule
	(goal escrowing ri-crossbow)
	(escrow-amount gold >= 75)
=>
	(set-escrow-percentage gold 0))
(defrule
	(goal underattack yes)
	(goal escrowing ri-crossbow)
=>
	(release-escrow food)
	(release-escrow gold)
	(set-escrow-percentage food 0)
	(set-escrow-percentage gold 0)
	(set-goal escrowing 0))
(defrule
	(goal escrowing ri-crossbow)
	(can-research-with-escrow ri-crossbow)
=>
	(release-escrow food)
	(release-escrow gold)
	(set-escrow-percentage food 0)
	(set-escrow-percentage gold 0)
	(research ri-crossbow)
	(set-goal escrowing 0))
(defrule
(or	(unit-type-count-total monk >= 3)
	(unit-type-count-total archer-line >= 5))
	(unit-type-count-total archer-line >= 3)
	(can-research ri-crossbow)
=>
	(research ri-crossbow))
