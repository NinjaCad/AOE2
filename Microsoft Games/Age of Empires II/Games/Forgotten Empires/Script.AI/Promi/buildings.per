#load-if-defined UP-ALLY-IN-GAME
(defrule
(or	(goal position-goal pocket)
(or	(goal defend yes)
(or	(building-type-count-total watch-tower >= 1)
(or	(building-type-count-total castle >= 1)
(or	(building-type-count-total town-center < 1)
	(goal underattack yes))))))
=>
	(up-jump-rule 1))
(defrule
	(building-type-count-total mining-camp == 1)
	(strategic-number my-sn-military-superiority <= 0)
	(players-current-age focus-player <= feudal-age)
	(players-military-population any-enemy >= 2)
	(up-compare-goal strategy != r-flush)
	(up-compare-goal strategy != krush)
	(can-build watch-tower)
=>
	(set-strategic-number sn-ignore-tower-elevation 1)
	(up-set-placement-data my-player-number mining-camp c: 2)
	(up-build place-control 0 c: watch-tower)
	(disable-self))
#else ; no ally
(defrule
	(building-type-count-total mining-camp == 1)
	(strategic-number my-sn-military-superiority <= -1)
	(players-current-age focus-player <= feudal-age)
	(players-military-population any-enemy >= 2)
	(up-compare-goal strategy != r-flush)
	(up-compare-goal strategy != krush)
	(can-build watch-tower)
=>
	(set-strategic-number sn-ignore-tower-elevation 1)
	(up-set-placement-data my-player-number mining-camp c: 2)
	(up-build place-control 0 c: watch-tower)
	(disable-self))
#end-if
#end-if
#end-if
#end-if
#end-if

#end-if



(defrule
	(goal milunits no)
	(building-type-count-total town-center < 4)
	(current-age >= castle-age)
	(goal underattack no)
	(housing-headroom >= 6)
	(unit-type-count villager-wood >= 10)
(or	(unit-type-count villager-stone >= 3)
	(stone-amount >= 100))
	(wood-amount >= 120)
	(goal increase-ts 0)
	(goal escrowing 0)
	(building-available town-center)
=>
	(set-escrow-percentage wood 100)
	(set-escrow-percentage stone 100)
	(set-goal escrowing town-center))
(defrule
	(goal strategy r-flush)
	(building-type-count-total town-center < 3)
	(current-age >= castle-age)
	(goal underattack no)
	(housing-headroom >= 8)
	(building-type-count-total archery-range >= 2)
	(strategic-number my-sn-military-superiority >= 2)
	(unit-type-count villager-wood >= 10)
;(or	(unit-type-count villager-stone >= 3)
	(stone-amount >= 100);)
	(goal increase-ts 0)
	(goal escrowing 0)
	(building-available town-center)
=>
	(set-escrow-percentage wood 100)
	(set-escrow-percentage stone 100)
	(set-goal escrowing town-center))
(defrule
	(goal strategy krush)
	(building-type-count-total town-center < 3)
;	(current-age >= castle-age)
	(goal underattack no)
	(housing-headroom >= 8)
	(building-type-count-total stable >= 2)
	(strategic-number my-sn-military-superiority >= 1)
	(unit-type-count villager-wood >= 10)
(or	(unit-type-count villager-stone >= 3)
	(stone-amount >= 100))
	(goal increase-ts 0)
	(goal escrowing 0)
	(building-available town-center)
=>
	(set-escrow-percentage wood 100)
	(set-escrow-percentage stone 100)
	(set-goal escrowing town-center))
(defrule
	(goal escrowing town-center)
(or	(escrow-amount wood >= 275)
	(and	(civ-selected briton)
		(escrow-amount wood >= 138)))
=>
	(set-escrow-percentage wood 0))
(defrule
	(goal escrowing town-center)
	(escrow-amount stone >= 100)
=>
	(set-escrow-percentage stone 0))
(defrule
(or	(housing-headroom < 3)
(or	(building-type-count-total town-center >= 5)
(or	(and	(stone-amount < 100)
		(unit-type-count villager-stone <= 1))
	(goal underattack yes))))
	(goal escrowing town-center)
=>
	(release-escrow wood)
	(release-escrow stone)
	(set-escrow-percentage wood 0)
	(set-escrow-percentage stone 0)
	(set-goal escrowing 0))
(defrule
	(goal strategy krush)
	(building-type-count-total town-center < 3)
(or	(escrow-amount wood >= 275)
	(and	(civ-selected briton)
		(escrow-amount wood >= 138)))
	(escrow-amount stone >= 100)
	(goal escrowing town-center)
	(building-available town-center)
;	(goal increase-ts 0)
=>
;	(set-strategic-number sn-camp-max-distance 45)
;below	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-strategic-number sn-town-center-placement 0)
	(up-assign-builders c: town-center-foundation c: 4)
	(set-goal increase-ts town-center)
	(enable-timer increase-ts-timer 6))
(defrule
	(goal milunits no)
	(building-type-count-total town-center < 5)
(or	(escrow-amount wood >= 275)
	(and	(civ-selected briton)
		(escrow-amount wood >= 138)))
	(escrow-amount stone >= 100)
	(goal escrowing town-center)
	(building-available town-center)
;	(goal increase-ts 0)
=>
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-strategic-number sn-town-center-placement 0)
	(up-assign-builders c: town-center-foundation c: 4)
	(set-goal increase-ts town-center)
	(enable-timer increase-ts-timer 6))



#load-if-defined WONDER-RACE
(defrule
	(goal wwonder no)
=>
	(set-goal wwonder yes)
	(disable-self))
(defrule
        (building-type-count-total market < 1)
	(wood-amount >= 175)
	(building-available market)
	(goal increase-ts 0)
=>
	(set-goal increase-ts market)
	(enable-timer increase-ts-timer 6))
(defrule
        (building-type-count-total blacksmith < 1)
        (building-type-count-total market >= 1)
	(wood-amount >= 150)
	(building-available blacksmith)
	(goal increase-ts 0)
=>
	(set-goal increase-ts blacksmith)
	(enable-timer increase-ts-timer 6))
(defrule
        (building-type-count-total monastery < 1)
	(wood-amount >= 175)
	(building-available monastery)
	(goal increase-ts 0)
=>
	(set-goal increase-ts monastery)
	(enable-timer increase-ts-timer 6))
(defrule
(or	(strategic-number sn-current-age >= imperial)
	(strategic-number my-sn-military-superiority >= 0))
        (building-type-count-total siege-workshop < 1)
	(building-available siege-workshop)
	(wood-amount >= 200)
	(goal increase-ts 0)
=>
	(set-goal increase-ts siege-workshop)
	(enable-timer increase-ts-timer 6))

#end-if

#load-if-defined VICTORY-STANDARD
(defrule
	(goal nomad no)
	(goal landnomad no)
(or	(building-type-count-total wonder >= 1)
	(and	(hold-relics)
		(up-compare-goal gl-relics >= 5)))
	(building-type-count-total gate < 5)
	(can-build-gate 2)
=>
	(build-gate 2))

(defrule
	(goal nomad no)
	(goal landnomad no)
(or	(building-type-count-total wonder >= 1)
	(and	(hold-relics)
		(up-compare-goal gl-relics >= 5)))
	(can-build-wall 2 stone-wall-line)
=>
	(build-wall 2 stone-wall-line))
#end-if

(defrule
	(game-time > 300)
	(building-type-count-total wonder <= 0)
(nand	(hold-relics)
	(up-compare-goal gl-relics >= 5))
(or	(population >= del-civ-pop)
	(and	(civilian-population >= up-max-civ)
		(military-population >= 50)))
=>
	(up-delete-objects c: wall-class c: 32767)
	(up-delete-objects c: gate-class c: 32767)
	(disable-self))

(defrule
	(timer-triggered embassy) ; 10 sec timer
(or	(up-pending-objects c: farm <= 0)
(or	(and	(building-type-count farm >= 1)
		(unit-type-count villager-farmer <= 0))
(or	(town-under-attack)
(or	(goal defend yes)
(or	(building-type-count town-center == 0)
	(unit-type-count-total villager < 3))))))
=>
	(up-delete-distant-farms s: sn-maximum-food-drop-distance))
(defrule
	(timer-triggered MSuperiority) ; 30 sec timer
=>
	(up-delete-distant-farms s: sn-maximum-food-drop-distance))

(defrule ; debug
	(up-pending-objects c: blacksmith >= 1)
	(goal increase-ts blacksmith)
=>
	(set-goal increase-ts 0)
	(disable-self))
(defrule ; debug
	(up-pending-objects c: university >= 1)
	(goal increase-ts university)
=>
	(set-goal increase-ts 0)
	(disable-self))

(defrule
	(goal attacking yes)
(or	(goal increase-ts town-center)
	(goal escrowing town-center))
	(can-build-with-escrow town-center)
=>
	(set-strategic-number sn-maximum-town-size 12)
	(chat-local-to-self "Resetting ts for TC.")); until i've found a better way

(defrule
;	(goal increase-ts town-center)
	(goal escrowing town-center)
	(can-build-with-escrow town-center)
=>
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-escrow-percentage wood 0)
	(set-escrow-percentage stone 0)
	(release-escrow wood)
	(release-escrow stone)
	(build town-center)
	(set-goal escrowing 0)
	(set-goal increase-ts 2))

(defrule
	(goal increase-ts town-center)
	(up-compare-goal escrowing != town-center)
	(can-build town-center)
=>
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(build town-center)
	(set-goal increase-ts 2))

(defrule
	(goal increase-ts castle)
	(can-build castle)
=>
	(build castle)
	(set-goal increase-ts 2))

(defrule
(or	(up-pending-objects c: house == 0)
	(and	(strategic-number sn-current-age >= dfeudal)
		(up-pending-objects c: house < 3))) ; real up-pending is in the building rules
	(goal increase-ts house)
	(can-build house)
=>
	(build house)
	(set-goal increase-ts 2))

(defrule
(or	(up-pending-objects c: market == 0)
	(players-building-type-count any-ally market >= 1))
	(goal increase-ts market)
	(can-build market)
=>
	(build market)
	(set-goal increase-ts 2))

(defrule
	(up-pending-objects c: blacksmith == 0)
	(goal increase-ts blacksmith)
	(can-build blacksmith)
=>
	(build blacksmith)
	(set-goal increase-ts 2))

(defrule
	(goal increase-ts monastery)
	(can-build monastery)
=>
	(build monastery)
	(set-goal increase-ts 2))

(defrule
	(goal increase-ts barracks)
	(can-build barracks)
=>
	(build barracks)
	(set-goal increase-ts 2))

(defrule
	(goal increase-ts archery-range)
	(can-build archery-range)
=>
	(build archery-range)
	(set-goal increase-ts 2))

(defrule
	(goal increase-ts stable)
	(can-build stable)
=>
	(build stable)
	(set-goal increase-ts 2))

(defrule
	(up-pending-objects c: university == 0)
	(goal increase-ts university)
	(can-build university)
=>
	(build university)
	(set-goal increase-ts 2))

(defrule
	(goal increase-ts siege-workshop)
	(can-build siege-workshop)
=>
	(build siege-workshop)
	(set-goal increase-ts 2))

(defrule
(or	(building-type-count-total town-center < 1)
	(and	(unit-type-count-total villager < 7)
		(building-type-count town-center < 1)))
=>
	(up-jump-rule 2))

(defrule
(or	(unit-type-count-total villager < 1)
(or	(up-compare-goal increase-ts == 2);reverted
(or	(up-compare-goal increase-ts == 0)
(or	(strategic-number sn-maximum-town-size >= 70)
(or	(and	(strategic-number sn-current-age < imperial)
		(strategic-number sn-maximum-town-size >= 44))
	(and	(goal islands no)
		(strategic-number sn-maximum-town-size >= 50)))))))
=>
	(up-jump-rule 1))

(defrule
	(timer-triggered increase-ts-timer)
(or	(and	(military-population <= 1)
		(and	(population-headroom > 0)
			(housing-headroom < 0)))
	(or	(strategic-number sn-maximum-town-size < 20)
		(nor	(enemy-buildings-in-town)
			(goal underattack yes))))
;(or
;	(strategic-number sn-maximum-town-size < 48)
;	(goal islands yes))
;	(strategic-number sn-maximum-town-size < 60)
=>
	(enable-timer increase-ts-timer 6)
	(set-goal increase-ts 0)
	(up-modify-sn sn-maximum-town-size c:+ 2)
	(up-chat-data-to-player my-player-number "sn-maximum-town-size: %d" s: sn-maximum-town-size))

(defrule
;(or	(goal increase-ts house)
;	(and	(strategic-number sn-maximum-town-size < 48)
		(goal increase-ts 2)
;)
;)
=>
	(set-goal increase-ts 0); building already placed
	(disable-timer increase-ts-timer))