	(set-escrow-percentage gold 0)
	(set-escrow-percentage stone 0)
	(release-escrow wood)
	(release-escrow gold)
	(release-escrow stone)
	(set-goal escrowing 0)
	(up-set-placement-data my-player-number -1 c: -1)
	(up-build place-control 0 c: wonder))
