	(game-time >= 60)
	(game-time < 90); == 60 seemed not to fire sometimes (cause of speedhack?)
	(goal strategy drush)
=>
	(chat-to-player my-player-number "I will attempt to drush.")
	(chat-to-player every-ally "I will attempt to drush.")
	(disable-self))
(defrule
	(game-time >= 60)
	(game-time < 90); == 60 seemed not to fire sometimes (cause of speedhack?)
	(goal strategy r-flush)
=>
	(chat-to-player my-player-number "I will flush.")
	(chat-to-player every-ally "I will flush.")
	(disable-self))
(defrule
	(game-time >= 60)
	(game-time < 90); == 60 seemed not to fire sometimes (cause of speedhack?)
	(goal strategy krush)
=>
	(chat-to-player my-player-number "I will knight-rush the enemy.")
	(chat-to-player every-ally "I will knight-rush the enemy.")
