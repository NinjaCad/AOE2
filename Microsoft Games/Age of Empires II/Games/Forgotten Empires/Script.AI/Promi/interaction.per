=>
	(set-goal assistance yes)
	(chat-local-to-self "An ally is assisting us in combat."))

(defrule
	(goal assistance yes)
	(goal assisting-ally-1 no)
	(goal assisting-ally-2 no)
	(goal assisting-ally-3 no)
	(goal assisting-ally-4 no)
	(goal assisting-ally-5 no)
	(goal assisting-ally-6 no)
	(goal assisting-ally-7 no)
	(goal assisting-ally-8 no)
=>
	(set-goal assistance no)
	(chat-local-to-self "No ally is assisting us in combat anymore."))
;===================================================================
;  Embassy
;===================================================================
(defrule
	(true)
=>
	(set-goal 420 275)
	(set-goal 421 275)
	(enable-timer embassy 1)
	(disable-self))

(defrule
	(timer-triggered embassy)
=>	
	(up-get-player-fact my-player-number resource-amount amount-food g-food)
	(up-get-player-fact my-player-number resource-amount amount-wood g-wood)	
	(up-get-player-fact my-player-number resource-amount amount-gold g-gold)
	(up-get-player-fact my-player-number resource-amount amount-stone g-stone)
	(up-get-player-fact my-player-number building-type-count-total town-center g-number-town-centers)
	(up-get-player-fact my-player-number building-type-count market g-number-markets)
	(up-get-player-fact my-player-number current-age 0 g-current-age)
	(up-get-player-fact my-player-number resource-amount amount-relics g-number-relics)
	(up-get-player-fact my-player-number population 0 g-population)
	(up-get-player-fact my-player-number unit-type-count villager g-number-villagers)
	(up-get-player-fact my-player-number unit-type-count monastery g-number-monasteries)
	(up-get-player-fact my-player-number housing-headroom 0 g-housing-room)
	(up-get-player-fact my-player-number unit-type-count monk g-number-monks)
	(up-get-point position-self position-self-x))

(defrule
	(timer-triggered embassy)
=>
	(disable-timer embassy)
	(enable-timer embassy 10))
;===================================================================
; Chats
;===================================================================
#load-if-defined UP-HUMAN-IN-GAME
(defrule
	(true)
=>
	(generate-random-number 100)
	(up-get-fact random-number 0 gl-random-number)
	(disable-self))
(defrule
	(goal strategy r-flush)
	(current-age == feudal-age)
	(current-age-time >= 60)
	(goal gl-random-number 98)
=>
	(chat-to-player every-enemy "They certainly won't expect my scorpion rush! >:D")
	(enable-timer wrongchat 4)
	(disable-self))
#load-if-defined UP-ALLY-IN-GAME
(defrule
	(strategic-number sn-current-age == dark)
	(current-age-time >= 540)
	(goal underattack no)
	(goal gl-random-number 99)
=>
	(chat-to-player every-enemy "Alright, now we take our militias and attack!")
	(enable-timer wrongchat 4)
	(disable-self))
#end-if
#load-if-not-defined AZTEC-CIV
#load-if-not-defined INCAN-CIV
#load-if-not-defined MAYAN-CIV
(defrule
	(goal milunits no)
	(strategic-number sn-current-age >= castlea)
	(current-age-time >= 90)
	(goal underattack no)
	(goal gl-random-number 100)
=>
	(chat-to-player every-enemy "The best of my knights are already on their way to your base.")
	(chat-to-player every-enemy "Be wise and resign now to end this peacefully.")
	(disable-self))
#end-if
#end-if
#end-if

(defrule
	(timer-triggered wrongchat)
=>
	(disable-timer wrongchat)
	(chat-to-player every-enemy "Oops, wrong chat..."))

#end-if; hooman ingame