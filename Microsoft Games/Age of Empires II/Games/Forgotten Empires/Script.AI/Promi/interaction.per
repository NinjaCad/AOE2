(defrule
(or	(taunt-detected my-player-number 36)
	(taunt-detected any-ally 36))
	(up-compare-goal strategy != usual)
=>
	(acknowledge-taunt every-ally 36)
	(acknowledge-taunt my-player-number 36)
	(set-goal milunits yes)
	(set-goal strategy usual)
	(set-goal attackprioritychange yes)
	(chat-to-player my-player-number "1Understood, I will reset my strategy.")
	(chat-to-allies "1Understood, I will reset my strategy."))

(defrule
(or	(strategic-number my-sn-military-superiority <= -1)
(or	(up-enemy-units-in-town > 40)
(or	(and	(military-population < 30)
		(up-enemy-units-in-town > 25))
	(and	(military-population < 18)
		(up-enemy-units-in-town > 15)))))
	(goal underattack yes)
	(goal defendchat yes)
=>
	(chat-to-player every-ally "222Help, i'm under heavy attack!")
	(set-goal defendchat no)
	(enable-timer defend-timer 90))

(defrule
	(timer-triggered defend-timer)
=>
	(disable-timer defend-timer)
	(set-goal defendchat yes))

(defrule
	(taunt-detected any-ally 31)
(or	(and	(strategic-number teamsuperiority >= 1)
		(military-population >= 22))
(or	(military-population >= 50)
(or	(strategic-number my-sn-military-superiority >= 2)
	(population >= max-civ-pop))))
	(goal attacking no)
=>
	(set-goal attacking yes)
	(acknowledge-taunt this-any-ally 31)
	(chat-to-player every-ally "Attacking.")); test

(defrule
	(taunt-detected my-player-number 31)
(or	(and	(strategic-number teamsuperiority >= 1)
		(military-population >= 22))
(or	(military-population >= 50)
(or	(strategic-number my-sn-military-superiority >= 2)
	(population >= max-civ-pop))))
	(goal attacking no)
=>
	(set-goal attacking yes)
	(acknowledge-taunt my-player-number 31)
	(chat-to-player every-ally "Attacking.")); test

