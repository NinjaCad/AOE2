(defrule
(or	(taunt-detected my-player-number 250)
(or	(taunt-detected any-ally 250)
	(taunt-detected any-enemy 250)))
=>
	(chat-to-player my-player-number "Promi 1.4k")
	(chat-to-player every-ally "Promi 1.4k")
	(chat-to-player this-any-enemy "Promi 1.4k")
;	(acknowledge-taunt my-player-number 250)
;	(acknowledge-taunt every-ally 250); strat
	(acknowledge-taunt every-enemy 250))
(defrule
	(game-time >= 10)
=>
	(chat-to-player every-computer "Promi 1.4k")
	(chat-to-all "gl hf")
	(disable-self))
(defrule
(or	(taunt-detected my-player-number 250)
	(taunt-detected any-ally 250))
	(goal strategy drush)
=>
	(chat-to-player my-player-number "I will attempt to drush.")
	(chat-to-player every-ally "I will attempt to drush.")
	(acknowledge-taunt my-player-number 250)
	(acknowledge-taunt every-ally 250))
(defrule
(or	(taunt-detected my-player-number 250)
	(taunt-detected any-ally 250))
	(goal strategy r-flush)
=>
	(chat-to-player my-player-number "I will flush with archers and skirms.")
	(chat-to-player every-ally "I will flush with archers and skirms.")
	(acknowledge-taunt my-player-number 250)
	(acknowledge-taunt every-ally 250))
(defrule
(or	(taunt-detected my-player-number 250)
	(taunt-detected any-ally 250))
	(goal strategy krush)
=>
	(chat-to-player my-player-number "I will rush the enemy with knights.")
	(chat-to-player every-ally "I will rush the enemy with knights.")
	(acknowledge-taunt my-player-number 250)
	(acknowledge-taunt every-ally 250))
(defrule
(or	(taunt-detected my-player-number 250)
	(taunt-detected any-ally 250))
	(goal milunits no)
=>
	(chat-to-player my-player-number "I'm booming without military.")
	(chat-to-player every-ally "I'm booming without military.")
	(acknowledge-taunt my-player-number 250)
	(acknowledge-taunt every-ally 250))
(defrule
(or	(taunt-detected my-player-number 250)
	(taunt-detected any-ally 250))
(or	(goal milunits yes)
	(goal milunits 101))
=>
	(chat-to-player my-player-number "No aggressive strategy selected.")
	(chat-to-player every-ally "No aggressive strategy selected.")
	(chat-to-player every-ally "Army composition depends on my enemy.")
	(acknowledge-taunt my-player-number 250)
	(acknowledge-taunt every-ally 250))

(defrule
	(taunt-detected any-ally 249)
=>
	(up-get-fact food-amount 0 math-goal)
	(up-chat-data-to-player this-any-ally "Food: %d" g: math-goal)
	(up-get-fact wood-amount 0 math-goal)
	(up-chat-data-to-player this-any-ally "Wood: %d" g: math-goal)
	(up-get-fact gold-amount 0 math-goal)
	(up-chat-data-to-player this-any-ally "Gold: %d" g: math-goal)
	(up-get-fact stone-amount 0 math-goal)
	(up-chat-data-to-player this-any-ally "Stone: %d" g: math-goal)
	(acknowledge-taunt this-any-ally 249))
(defrule
	(game-time >= 60)
	(game-time < 90); == 60 seemed not to fire sometimes (cause of speedhack?)
	(goal milunits no)
=>
	(chat-to-player my-player-number "I will attempt to boom.")
	(chat-to-player every-ally "I will attempt to boom.")
	(disable-self))
