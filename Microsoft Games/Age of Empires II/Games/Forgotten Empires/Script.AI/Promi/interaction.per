(defrule
	(goal attacking yes)
(not	(goal attacknotifier 1))
=>
	(set-goal attacknotifier 1))

(defrule
	(goal attacking no)
(not	(goal attacknotifier 0))
=>
	(set-goal attacknotifier 0))

(defrule
	(goal assisting-ally-1 no)
	(player-valid 1)
	(stance-toward 1 ally)
(not	(player-number 1))
	(strategic-number sn-target-player-number > 0)
	(up-allied-sn 1 sn-target-player-number s:== sn-target-player-number); An ally shares same target
	(up-allied-goal 1 attacknotifier g:== 1); and is attacknotifier it
=>
	(set-goal assisting-ally-1 yes))

(defrule
	(goal assisting-ally-1 yes)
	(strategic-number sn-target-player-number > 0)
(or	(up-allied-goal 1 sn-target-player-number s:!= sn-target-player-number); Ally doesn't target the same player anymore
	(up-allied-goal 1 attacknotifier g:!= 1)); Ally isn't attacknotifier anymore
=>
	(set-goal assisting-ally-1 no))

