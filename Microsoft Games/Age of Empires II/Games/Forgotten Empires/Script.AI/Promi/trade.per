	(goal underattack no)
	(goal uugoal yes)
	(population >= up-max-civ)
	(gold-amount > uu-gold2)
	(food-amount < uu-food2)
(or	(commodity-buying-price food < 150)
	(gold-amount > 1400))
	(current-age >= imperial-age)
	(building-type-count castle >= 1)
	(goal e-cata no)
	(can-buy-commodity food)
=>
