;================================================================
; Stone in general
;================================================================
#load-if-not-defined WONDER-RACE
(defrule
	(unit-type-count 124 == 0); stone-miners
	(unit-type-count 220 == 0)
	(building-type-count-total town-center <= 0)
	(wood-amount >= 275)
	(stone-amount < 100)
	(can-buy-commodity stone)
=>
	(chat-local-to-self "Buying stone for a towncenter.")
	(buy-commodity stone))
;================================================================
#load-if-not-defined HUN-CIV
(defrule
	(strategic-number my-sn-military-superiority >= 0)
(or	(building-type-count-total castle == 0)
	(and	(building-type-count-total castle < 2)
		(gold-amount > 1900)))
	(stone-amount < 650)
(or	(gold-amount > 1100)
	(and	(gold-amount > 300)
		(strategic-number sn-current-age >= imperial)))
	(can-buy-commodity stone)
=>
	(chat-local-to-self "Buying stone for a castle.")
	(buy-commodity stone))
#end-if
;================================================================
(defrule
	(unit-type-count 124 <= 0); stoneminers
	(unit-type-count 220 <= 0)
	(current-age >= castle-age)
(or	(goal escrowing town-center)
	(goal dreitc no))
	(building-type-count-total town-center < 3)
	(wood-amount >= 315)
	(stone-amount < 100)
	(can-buy-commodity stone)
=>
	(chat-local-to-self "Buying stone for a towncenter.")
	(buy-commodity stone))
;================================================================
(defrule
	(goal milunits no)
	(current-age >= castle-age)
(or	(goal escrowing town-center)
	(goal dreitc no))
	(building-type-count-total town-center < 4)
	(wood-amount >= 315)
	(stone-amount < 100)
	(can-buy-commodity stone)
=>
	(chat-local-to-self "Buying stone for a towncenter.")
	(buy-commodity stone))
;================================================================
(defrule
	(goal underattack no)
	(strategic-number my-sn-military-superiority >= 0)
	(building-type-count-total castle < 5)
	(stone-amount < 650)
(or	(gold-amount > 8000)
	(and	(or	(unit-type-count-total trade-cart >= 15)
			(unit-type-count-total trade-cog >= 15))
		(gold-amount > 5000)))
	(commodity-buying-price stone < 600)
	(can-buy-commodity stone)
=>
	(chat-local-to-self "Buying stone for a castle.")
	(buy-commodity stone))
;================================================================
(defrule
	(goal underattack no)
	(strategic-number my-sn-military-superiority >= 0)
	(building-type-count-total castle < 10)
	(stone-amount < 650)
(or	(gold-amount > 10200)
	(and	(or	(unit-type-count-total trade-cart >= 15)
			(unit-type-count-total trade-cog >= 15))
		(gold-amount > 5500)))
	(commodity-buying-price stone < 600)
	(can-buy-commodity stone)
=>
	(chat-local-to-self "Buying stone for a castle.")
	(buy-commodity stone))
;================================================================
#load-if-defined VICTORY-STANDARD
(defrule
	(commodity-buying-price stone >= 300)
	(unit-type-count 124 >= 2); stoneminers
	(unit-type-count 220 >= 2)
=>
	(up-jump-rule 2))
;================================================================
(defrule
	(goal wwonder yes)
	(building-type-count-total town-center >= 1)
	(building-type-count-total wonder < 1)
	(players-building-type-count any-ally wonder == 0)
	(wood-amount >= 1100)
	(gold-amount >= 1400)
	(stone-amount < 1000)
	(goal underattack no)
	(can-buy-commodity stone)
=>
	(chat-local-to-self "Buying stone for a wonder.")
	(buy-commodity stone))
;================================================================
(defrule
	(goal nomad no)
	(goal landnomad no)
(or	(building-type-count-total wonder >= 1)
	(and	(hold-relics)
		(up-compare-goal gl-relics >= 5)))
	(wall-completed-percentage 2 < 100)
	(gold-amount >= 200)
	(stone-amount < 100)
	(can-buy-commodity stone)
=>
	(chat-local-to-self "Buying stone for walls.")
	(buy-commodity stone))
#end-if
;================================================================
(defrule
	(building-type-count-total castle >= 3)
	(building-type-count-total town-center >= 3)
	(strategic-number my-sn-military-superiority <= -2)
	(military-population < 20)
	(goal underattack yes)
	(gold-amount < 100)
	(commodity-selling-price stone > 200)
	(can-sell-commodity stone)
=>
	(chat-local-to-self "Selling stone.")
	(sell-commodity stone))
;================================================================
; Food excess
;================================================================
(defrule
	(food-amount > 700)
	(gold-amount < 100)
	(commodity-selling-price food > 40)
	(can-sell-commodity food)
=>
	(chat-local-to-self "Selling food.")
	(sell-commodity food))
;================================================================
(defrule
	(food-amount > 1000)
	(gold-amount < 100)
	(can-sell-commodity food)
=>
	(chat-local-to-self "Selling food.")
	(sell-commodity food))
