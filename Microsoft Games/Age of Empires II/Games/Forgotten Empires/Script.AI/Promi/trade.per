;================================================================
(defrule
	(goal underattack yes)
=>
	(up-jump-rule 7))
;================================================================
(defrule
	(goal underattack no)
	(goal uugoal yes)
	(population >= up-max-civ)
	(gold-amount < uu-gold)
	(food-amount > uu-food)
	(food-amount >= 200)
(or	(commodity-selling-price food > 23)
	(food-amount > 1400))
	(current-age >= imperial-age)
	(building-type-count castle >= 1)
	(goal e-cata no)
	(can-sell-commodity food)
=>
	(chat-local-to-self "Selling food for Elite-X.")
	(sell-commodity food))
;================================================================
