;=========================================================
; Trade Carts
;=========================================================
(defrule
	(goal islands no)
; test	(strategic-number my-sn-military-superiority >= 0)
	(players-building-type-count any-ally market > 0)
(or	(wood-amount > 725)
	(goal dreitc yes))
(or	(building-type-count-total stable >= 1)
	(building-type-count-total archery-range >= 2))
	(unit-type-count-total 178 <= 1); Dead trade cart (empty)
	(unit-type-count-total 205 <= 2); Dead trade cart (full)
	(unit-type-count-total trade-cart < 5)
	(can-train trade-cart)
=>
	(train trade-cart))
;=========================================================
