;=========================================================
; Civilian units
;=========================================================
;=========================================================
; Transport ships
;=========================================================
(defrule
	(goal islands yes)
(or	(population >= max-civ-pop)
	(goal attacking yes))
(or	(population >= max-civ-pop)
	(and	(soldier-count >= 25)
		(or	(warboat-count >= 11)
			(goal enemy-boats no))))
	(unit-type-count-total transport-ship < 6)
	(can-train transport-ship)
=>
	(train transport-ship))
;=========================================================
; Important - Siege
;=========================================================
(defrule
	(goal milunits yes)
	(goal underattack no)
(or	(military-population > 40)
(or	(strategic-number my-sn-military-superiority >= 2)
(or	(goal attacking yes)
	(goal researchplan yes))))
	(unit-type-count-total trebuchet-set < 3)
	(can-train trebuchet)
=>
	(train trebuchet))
;=========================================================
(defrule
	(goal milunits yes)
	(strategic-number sn-current-age >= imperial)
(or	(military-population > 20)
(or	(strategic-number my-sn-military-superiority >= 1)
(or	(goal attacking yes)
	(goal researchplan yes))))
(or	(goal underattack no)
	(strategic-number my-sn-military-superiority >= 0))
	(unit-type-count-total battering-ram-line < 6)
	(can-train battering-ram-line)
=>
	(train battering-ram-line))
;=========================================================
; Villagers
;=========================================================
(defrule
	(up-compare-goal strategy == r-flush)
	(population < del-civ-pop)
	(civilian-population < up-max-civ)
(or	(unit-type-count-total villager < 22)
	(and	(food-amount <= 420)
		(unit-type-count-total villager < 25)))
	(strategic-number sn-current-age == dark)
	(can-train villager)
=>
	(disable-timer FDrop)
	(enable-timer FDrop 21)
	(train villager))
(defrule
	(up-compare-goal strategy == r-flush)
=>
	(up-jump-rule 3))
;=========================================================
(defrule
	(population < del-civ-pop)
	(civilian-population < up-max-civ)
	(unit-type-count-total villager < darkvils);31/28
	(food-amount < 800)
(or	(goal enemy-goal 0)
	(goal strategy drush))
	(strategic-number sn-current-age == dark)
	(can-train villager)
=>
	(disable-timer FDrop)
	(enable-timer FDrop 21)
	(train villager))
;=========================================================
(defrule
	(population < del-civ-pop)
	(civilian-population < up-max-civ)
	(unit-type-count-total villager < 27)
	(strategic-number sn-current-age == dark)
(or	(up-compare-goal enemy-goal != 0)
	(food-amount <= 420))
	(can-train villager)
=>
	(disable-timer FDrop)
	(enable-timer FDrop 21)
	(train villager))
;=========================================================
(defrule
	(population < del-civ-pop)
	(civilian-population < up-max-civ)
	(unit-type-count-total villager < 24)
	(strategic-number sn-current-age == dark)
	(can-train villager)
=>
	(disable-timer FDrop)
	(enable-timer FDrop 21)
	(train villager))
;=========================================================
(defrule
	(population < del-civ-pop)
	(civilian-population < up-max-civ)
(or	(goal enemy-goal 0)
	(goal strategy drush))
	(building-type-count town-center >= 2)
	(unit-type-count-total villager < 40)
	(food-amount < 450)
	(strategic-number sn-current-age <= dfeudal)
	(can-train villager)
=>
	(train villager))
;=========================================================
(defrule
	(population < del-civ-pop)
	(civilian-population < up-max-civ)
	(unit-type-count-total villager < 23); for >=normal resources starts or sth else
	(strategic-number sn-current-age == feudal)
	(can-train villager)
=>
	(train villager))
;=========================================================
(defrule
	(population < del-civ-pop)
	(civilian-population < up-max-civ)
	(food-amount >= 830)
	(gold-amount <= 170)
(not	(can-research-with-escrow castle-age))
	(dropsite-min-distance wood >= 0)
	(dropsite-min-distance wood < 255)
	(strategic-number sn-current-age == feudal)
	(can-train villager)
=>
	(train villager))
;=========================================================
(defrule
	(population < del-civ-pop)
	(civilian-population < up-max-civ)
	(goal enemy-goal flush)
(or	(game-time <= 1350)
	(and	(game-time <= 1440)
		(food-amount <= 650)))
	(food-amount <= 720)
	(goal woodavailable yes)
(or	(strategic-number sn-current-age == feudal)
	(strategic-number sn-current-age == dfeudal))
	(can-train villager)
=>
	(train villager))
;=========================================================
(defrule
	(population < del-civ-pop)
	(civilian-population < up-max-civ)
	(food-amount <= 600)
	(goal woodavailable yes)
(or	(strategic-number sn-current-age == feudal)
	(strategic-number sn-current-age == dfeudal))
	(can-train villager)
=>
	(train villager))
;=========================================================
(defrule
	(population < del-civ-pop)
	(civilian-population < up-max-civ)
	(food-amount >= 750)
	(building-type-count blacksmith == 0)
	(building-type-count stable == 0)
	(building-type-count market == 0)
	(goal woodavailable yes)
	(strategic-number sn-current-age == feudal)
	(can-train villager)
=>
	(train villager))
;=========================================================
(defrule
	(population < del-civ-pop)
	(civilian-population < up-max-civ)
	(food-amount >= 850)
(or	(building-type-count blacksmith == 0)
	(gold-amount <= 170))
;(not	(can-research-with-escrow castle-age)) ^ stops CA research delay with the new queuesys
	(goal woodavailable yes)
	(strategic-number sn-current-age == feudal)
	(can-train villager)
=>
	(train villager))
