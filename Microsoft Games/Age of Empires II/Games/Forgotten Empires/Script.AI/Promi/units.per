;=========================================================
; R-Flush.
;=========================================================
(defrule
(or	(up-compare-goal milunits != r-flush)
(or	(goal siegereq no)
(or	(and	(and	(idle-farm-count <= 0)
			(strategic-number my-sn-military-superiority >= 2))
		(wood-amount < 60))
	(and	(dropsite-min-distance wood > 5)
		(wood-amount < 100)))))
=>
	(up-jump-rule 11))
(defrule
	(and	(current-age >= castle-age)
		(and	(wood-amount < 200)
			(building-type-count-total siege-workshop <= 0)))
=>
	(up-jump-rule 10))
;=========================================================
(defrule
;	(goal milunits r-flush)
(or	(military-population > 20)
(or	(strategic-number my-sn-military-superiority >= 1)
(or	(goal attacking yes)
	(goal researchplan yes))))
(or	(goal underattack no)
	(strategic-number my-sn-military-superiority >= 0))
	(unit-type-count-total battering-ram-line < 2)
	(can-train battering-ram-line)
=>
	(train battering-ram-line))
