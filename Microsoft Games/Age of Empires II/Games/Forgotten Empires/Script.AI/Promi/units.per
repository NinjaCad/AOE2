	(population >= del-civ-pop)))
	(players-building-type-count any-ally market > 0)
(or	(wood-amount > 725)
	(goal dreitc yes))
	(unit-type-count-total 178 <= 1); Dead trade cart (empty)
	(unit-type-count-total 205 <= 2); Dead trade cart (full)
	(unit-type-count-total trade-cart < 20)
	(can-train trade-cart)
=>
	(train trade-cart))
#end-if
