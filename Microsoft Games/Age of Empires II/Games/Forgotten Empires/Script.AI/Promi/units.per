	(goal siegereq yes)
	(goal spears yes)
	(strategic-number cavalry >= 25)
	(food-amount >= 76)
(or	(up-research-status c: ri-hand-cart >= research-pending)
(or	(goal defend yes)
	(strategic-number my-sn-military-superiority <= 0)))
	(unit-type-count-total spearman-line < 50)
	(can-train spearman-line)
=>
	(train spearman-line))
