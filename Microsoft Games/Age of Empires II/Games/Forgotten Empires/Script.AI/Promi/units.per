(defrule
	(goal milunits yes)
	(goal enemy-goal drush)
	(strategic-number sn-current-age == dark)
	(players-military-population focus-player >= 3)
(or	(food-amount >= 110)
	(strategic-number my-sn-military-superiority <= -2))
	(strategic-number my-sn-military-superiority <= -1)
	(unit-type-count-total militiaman-line < 6)
	(can-train militiaman-line)
=>
	(train militiaman-line))
;=========================================================
(defrule
	(goal milunits yes)
(or	(can-research ri-two-handed-swordsman)
	(research-completed ri-two-handed-swordsman))
(or	(gold-amount < 100)
	(strategic-number my-sn-military-superiority <= -2))
(or	(players-unit-type-count focus-player spearman-line > 39)
	(players-unit-type-count focus-player skirmisher-line > 39))
	(strategic-number archers <= 25)
	(cc-players-unit-type-count 0 gold-mine < 3)
;	(unit-type-count-total militiaman-line < 80)
	(can-train militiaman-line)
=>
	(train militiaman-line))
;=========================================================
(defrule; early nomad scout
(or	(up-compare-goal nomad != no)
	(up-compare-goal landnomad != no))
	(goal underattack no)
	(goal defend no)
	(military-population <= 0)
(or	(food-amount >= 560)
	(strategic-number sn-current-age >= dfeudal))
	(can-train militiaman-line)
=>
	(train militiaman-line)
	(disable-self))
