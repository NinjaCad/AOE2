(defrule
	(dropsite-min-distance wood >= 7)
	(wood-amount < 110)
=>
	(up-jump-rule 8))
(defrule
	(goal fleet yes)
	(goal enemy-boats yes)
	(strategic-number sn-current-age == feudal)
	(warboat-count < up-max-civ)
	(building-type-count-total blacksmith >= 1)
(or	(gold-amount >= 230)
	(strategic-number sn-current-age > feudal))
	(warboat-count < 10)
	(can-train galley-line)
=>
	(train galley-line))
(defrule
	(goal fleet yes)
	(goal enemy-boats yes)
(or	(warboat-count < 25)
(or	(players-unit-type-count any-enemy galley-line >= 20)
	(players-unit-type-count any-enemy fire-ship-line >= 11)))
