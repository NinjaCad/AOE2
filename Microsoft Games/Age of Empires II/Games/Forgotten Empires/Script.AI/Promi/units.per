	(cc-players-unit-type-count 0 deep-fish >= 1))
	(food-amount < 600)
	(wood-amount > 600)
(or	(goal islands no)
	(unit-type-count-total transport-ship >= 1))
	(unit-type-count-total fishing-ship < 4)
	(can-train fishing-ship)
=>
	(train fishing-ship))
