(defrule
	(goal milunits yes)
	(goal e-cata yes)
	(strategic-number moenche < 15)
;(not	(players-unit-type-count focus-player spearman-line > 59))
	(goal siegereq yes)
;	(unit-type-count-total my-unique-unit-line < 80)
	(can-train my-unique-unit-line)
=>
	(train my-unique-unit-line))

#end-if

#load-if-defined FRANKISH-CIV

(defrule
	(goal milunits yes)
(or	(goal e-cata yes)
	(strategic-number cavalry >= 40))
	(strategic-number moenche < 15)
	(strategic-number cavalry >= 25)
	(strategic-number infantry <= 15)
	(strategic-number archers <= 10)
	(strategic-number gunpowder <= 10)
	(players-unit-type-count focus-player jaguar-man-line <= 15)
	(players-unit-type-count focus-player cataphract-line <= 15)
	(players-unit-type-count focus-player samurai-line <= 15)
	(goal siegereq yes)
	(unit-type-count-total my-unique-unit-line < 70)
	(can-train my-unique-unit-line)
=>
	(train my-unique-unit-line))

#end-if

